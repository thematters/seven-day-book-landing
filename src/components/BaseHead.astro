---
import {
  SITE_TITLE,
  SITE_SHORT,
  SITE_SUBTITLE,
  SITE_DESCRIPTION,
  SITE_LANG,
} from "../site.config";
import { withBase } from "../utils/paths";

interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const {
  title,
  fullTitle,
  description = SITE_DESCRIPTION,
  ogImage,
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
  noindex = false,
} = Astro.props;

const pageTitle =
  fullTitle ??
  (title ? `${title}｜${SITE_TITLE}` : `${SITE_SHORT}｜${SITE_SUBTITLE}`);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<link rel="icon" type="image/png" sizes="32x32" href={withBase("images/matters-favicon-32.png")} />
<link rel="icon" type="image/png" sizes="128x128" href={withBase("images/matters-favicon-128.png")} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase("images/matters-apple-touch-icon.png")} />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={new URL(withBase(ogImage), Astro.site).href} />}
<meta property="og:locale" content={SITE_LANG} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />

<!--
  Display 字型：jf-openhuninn 2.1（justfont 粉圓體）
  授權：SIL Open Font License 1.1（justfont 開源版），可商用、可 web font 部署、可 redistribute
  原始檔：jf-openhuninn-2.1.ttf（4.7 MB）→ subset 後 woff2（~500 KB）
  Subset 範圍：landing source 全文掃描出現的 ~2,800 個中文字 + ASCII + 常用標點 + Latin Ext
  Re-subset 流程：見 scripts/subset-openhuninn.sh（如有）
-->
<link rel="preload" href={withBase("fonts/jf-openhuninn-2.1.subset.woff2")} as="font" type="font/woff2" crossorigin />

<!-- Bebas Neue：徽章 #N 數字 / dignity sans-serif 數字佔位用 -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&display=swap" />
<!--
  金句牆內文字型：GenSenRounded 源泉圓體 TW（ButTaiwan，衍生自思源黑體）
  授權：SIL Open Font License 1.1（見 public/fonts/GenSenRounded-SIL_OFL_1.1.txt），可商用
  緣由：粉圓（open-huninn）不含簡體，金句是使用者產生、常含簡體，故金句本文＋署名改用繁簡通吃的源泉圓體
  原始檔：GenSenRounded2TW-M.otf（15 MB 全字集）→ subset 後 woff2（~600 KB）
  Subset 範圍：freewrite-featured + quote-wall 全文中文字 + ASCII + 常用標點；金句更新時重跑 scripts/subset-gensen.sh
  不 preload：只有博物館金句牆用到，載入該頁時才下載
-->
<style is:global set:html={`
  @font-face {
    font-family: 'jf-openhuninn';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('${withBase("fonts/jf-openhuninn-2.1.subset.woff2")}') format('woff2');
  }
  @font-face {
    font-family: 'GenSenRounded';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('${withBase("fonts/gensen-rounded-tw.subset.woff2")}') format('woff2');
  }
`}></style>
