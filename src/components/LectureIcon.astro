---
// 名家講座 icon — 一本翻開的書 + 上方光點，象徵作家朗讀與聆聽
// 與 GrandBadge.astro 同 viewBox 26x26，採 freewrite palette
interface Props {
  size?: number;
  title?: string;
}
const { size = 42, title = "名家講座" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 26 26"
  width={size}
  height={size}
  role="img"
  aria-label={title}
  class="lecture-icon-svg"
>
  <title>{title}</title>
  <circle cx="13" cy="13" r="11.5" fill="#F0F9FE" stroke="#83BAD1" stroke-width="1" />
  <!-- 講者燈光 -->
  <circle cx="13" cy="6.6" r="1.6" fill="#FFC688" />
  <path d="M11.4 7.8 L8.4 11.6" stroke="#FFC688" stroke-width="0.55" stroke-linecap="round" />
  <path d="M14.6 7.8 L17.6 11.6" stroke="#FFC688" stroke-width="0.55" stroke-linecap="round" />
  <!-- 翻開的書本 -->
  <path d="M4 13 Q9 11.6 12.6 13 L12.6 19.6 Q9 18.2 4 19.6 Z" fill="#FFFFFF" stroke="#1999D0" stroke-width="0.85" stroke-linejoin="round" />
  <path d="M22 13 Q17 11.6 13.4 13 L13.4 19.6 Q17 18.2 22 19.6 Z" fill="#FFFFFF" stroke="#1999D0" stroke-width="0.85" stroke-linejoin="round" />
  <line x1="13" y1="13" x2="13" y2="19.5" stroke="#045898" stroke-width="0.7" />
  <!-- 文字示意（兩條短線） -->
  <line x1="6.4" y1="14.8" x2="10.6" y2="14.4" stroke="#83BAD1" stroke-width="0.5" stroke-linecap="round" />
  <line x1="6.4" y1="16.4" x2="10.4" y2="16.0" stroke="#83BAD1" stroke-width="0.5" stroke-linecap="round" />
  <line x1="15.4" y1="14.4" x2="19.6" y2="14.8" stroke="#83BAD1" stroke-width="0.5" stroke-linecap="round" />
  <line x1="15.6" y1="16.0" x2="19.6" y2="16.4" stroke="#83BAD1" stroke-width="0.5" stroke-linecap="round" />
</svg>
