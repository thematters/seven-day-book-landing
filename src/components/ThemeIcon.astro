---
// 主題共創 icon — 七個圓點環繞中心，象徵七日書與合作方共同設計題目
// 與 GrandBadge.astro 同 viewBox 26x26，採 freewrite palette 線描風格
interface Props {
  size?: number;
  title?: string;
}
const { size = 42, title = "主題共創" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 26 26"
  width={size}
  height={size}
  role="img"
  aria-label={title}
  class="theme-icon-svg"
>
  <title>{title}</title>
  <circle cx="13" cy="13" r="11.5" fill="#F0F9FE" stroke="#83BAD1" stroke-width="1" />
  <circle cx="13" cy="13" r="2.4" fill="#045898" />
  <g fill="#1999D0">
    <circle cx="13" cy="4.6" r="1.4" />
    <circle cx="20.3" cy="8.8" r="1.4" />
    <circle cx="20.3" cy="17.2" r="1.4" />
    <circle cx="13" cy="21.4" r="1.4" />
    <circle cx="5.7" cy="17.2" r="1.4" />
    <circle cx="5.7" cy="8.8" r="1.4" />
  </g>
  <circle cx="13" cy="13" r="6.4" fill="none" stroke="#83BAD1" stroke-width="0.6" stroke-dasharray="0.6 1.6" />
</svg>
