---
// 舊路徑 redirect /archive/ → /museum/
// archive 已改名為 museum，保留此檔做 client-side redirect 避免外連 404
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";
import "../styles/seven-day-campaign.css";

const museumHref = withBase("museum/");
---

<BaseLayout
  title="七日書博物館"
  description="七日書博物館入口已移至 /museum/。"
>
  <main class="redirect-page">
    <div>
      <h1>七日書博物館頁已移動</h1>
      <p>新的入口在 /museum/，請前往：</p>
      <p class="redirect-page__action">
        <a
          class="button button--primary"
          href={museumHref}
          data-redirect-target>前往七日書博物館</a
        >
      </p>
    </div>
  </main>
  <script is:inline>
    const target = document
      .querySelector("[data-redirect-target]")
      ?.getAttribute("href");
    if (target) window.location.replace(target);
  </script>
</BaseLayout>
