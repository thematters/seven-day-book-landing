---
import BaseLayout from "../layouts/BaseLayout.astro";
import GrandBadge from "../components/GrandBadge.astro";
import MattersWordmark from "../components/MattersWordmark.astro";
import SevenDayBookLogo from "../components/SevenDayBookLogo.astro";
import WritingCardGrid from "../components/WritingCardGrid.astro";
import {
  audienceFaq,
  audiencePage,
  contactEmail,
  latestArticles,
  lectures,
  milestones,
  pastThemes,
  shared,
} from "../data/seven-day-campaign";
import "../styles/seven-day-campaign.css";
import { withBase } from "../utils/paths";

const partnersHref = withBase(shared.partnersHref);
const archiveHref = withBase("museum/");
const assetSrc = (src?: string) => {
  if (!src) return "";
  return src.startsWith("http") ? src : withBase(src);
};
const promptStateLabel: Record<string, string> = {
  past: "已開放",
  today: "今日題目",
  locked: "即將開放",
};
const nav = [
  { href: "#current", label: "本月主題" },
  { href: "#articles", label: "本期精選" },
  { href: "#passport", label: "我的足跡" },
  { href: "#badge", label: "大滿貫" },
  { href: "#themes", label: "過去主題" },
  { href: "#lectures", label: "名家講座" },
  { href: "#milestones", label: "歷年里程" },
  { href: "#faq", label: "FAQ" },
];
const marqueeAvatars = [
  ...shared.avatarWall.slice(0, 22),
  ...shared.avatarWall.slice(0, 22),
];
// 全部過去主題 → 4 張一頁，提供分頁點點切換
const themesPerPage = 4;
const themesPages: typeof pastThemes[] = [];
for (let i = 0; i < pastThemes.length; i += themesPerPage) {
  themesPages.push(pastThemes.slice(i, i + themesPerPage));
}

---

<BaseLayout title="七日書" description={audiencePage.description}>
  <div class="campaign-page" data-page="audience">
    <header class="sitebar">
      <a
        class="sitebar__brand"
        href="https://matters.town"
        target="_blank"
        rel="noopener"
        aria-label="Matters · 七日書"
      >
        <MattersWordmark size={18} />
        <span class="sitebar__dot" aria-hidden="true">·</span>
        <SevenDayBookLogo size={20} title="七日書" />
      </a>

      <nav class="sitebar__nav" aria-label="頁面導覽">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <div class="sitebar__actions">
        <a class="button button--quiet" href={partnersHref}
          >{audiencePage.hero.secondaryLabel}</a
        >
        <a
          class="button button--primary"
          href={shared.joinHref}
          target="_blank"
          rel="noopener"
        >
          {audiencePage.hero.primaryLabel}
        </a>
      </div>
    </header>

    <main>
      <section class="hero hero--stacked" aria-labelledby="hero-title">
        <div class="hero__banner" aria-hidden="true">
          <img
            src={assetSrc(audiencePage.currentIssue.cover)}
            alt=""
            loading="eager"
          />
        </div>
        <div class="hero__copy">
          <p class="eyebrow">{audiencePage.hero.eyebrow}</p>
          <h1 id="hero-title">{audiencePage.hero.headline}</h1>
          <p class="hero__lead">{audiencePage.hero.lead}</p>
          <p class="hero__live" aria-label="本期狀態">
            2026 年 5 月 七日書 ·
            <strong>{audiencePage.currentIssue.title}</strong>
            <span class="hero__live-dot" aria-hidden="true"></span>
            <span class="hero__live-status">現正進行中</span>
          </p>
          <div class="hero__actions">
            <a
              class="button button--primary"
              href={shared.joinHref}
              target="_blank"
              rel="noopener">加入寫作</a
            >
            <a class="button button--quiet" href={partnersHref}>洽談合作</a>
          </div>
        </div>
      </section>

      <section
        id="stats"
        class="section section--paper"
        aria-labelledby="stats-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">此刻在寫</p>
            <h2 id="stats-title">有人和你在同一週，把生活寫下來。</h2>
            <p>先看見同行的人，題目才不會像一張孤單的待辦清單。</p>
          </header>

          <div class="metrics-grid">
            {
              audiencePage.stats.map((item) => (
                <article class="metric-card">
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                  <small>{item.note}</small>
                </article>
              ))
            }
          </div>

          <div class="avatar-marquee" aria-label="近期參與作者頭像">
            <div class="avatar-marquee__track">
              {
                marqueeAvatars.map((avatar) => (
                  <a
                    href={`https://matters.town/@${avatar.handle}`}
                    target="_blank"
                    rel="noopener"
                    title={avatar.name}
                  >
                    <img
                      src={assetSrc(avatar.src)}
                      alt={avatar.name}
                      loading="lazy"
                    />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section
        id="current"
        class="section section--soft"
        aria-labelledby="current-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">本月主題</p>
            <h2 id="current-title">
              {audiencePage.currentIssue.title}：七道題目，一天打開一扇門。
            </h2>
            <p>
              {
                audiencePage.currentIssue.period
              } · {audiencePage.currentIssue.summary}
            </p>
          </header>

          <ol class="day-unlock-strip day-unlock-strip--full" aria-label="本期七道題目">
            {
              audiencePage.currentIssue.prompts.map((prompt) => (
                <li
                  class={`day-unlock-card day-unlock-card--${prompt.state}`}
                >
                  <div class="day-unlock-card__top">
                    <span>{prompt.date}</span>
                    <span>{promptStateLabel[prompt.state] ?? "題目"}</span>
                  </div>
                  <span class="day-unlock-card__day">{prompt.day}</span>
                  <h3>{prompt.title}</h3>
                  <p>{prompt.prompt}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section
        id="articles"
        class="section section--paper"
        aria-labelledby="articles-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">本期精選</p>
            <h2 id="articles-title">{audiencePage.articlesHeading}</h2>
            <p>{audiencePage.articlesNote}</p>
          </header>

          <WritingCardGrid articles={latestArticles} />
        </div>
      </section>

      <section
        id="passport"
        class="section section--soft"
        aria-labelledby="passport-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">個人足跡</p>
            <h2 id="passport-title">看看你在七日書留下的書寫旅程。</h2>
            <p>
              輸入你在 Matters 的帳號（例如 <code>mashbean</code>），看你曾在哪幾期參與、留下了哪些文字。
              所有資料來自 Matters 公開 API，不保存搜尋紀錄、不需要登入。
            </p>
          </header>

          <form class="passport-search" id="passport-search" novalidate>
            <label class="passport-search__field">
              <span class="passport-search__prefix" aria-hidden="true">@</span>
              <input
                type="text"
                name="handle"
                id="passport-handle"
                placeholder="你的 Matters 帳號"
                autocomplete="off"
                spellcheck="false"
                inputmode="text"
                required
              />
            </label>
            <button class="button button--primary" type="submit">
              查找書寫足跡 →
            </button>
          </form>

          <div
            class="passport-result"
            id="passport-result"
            role="status"
            aria-live="polite"
          >
            <p class="passport-hint">
              提示：你的帳號就是 Matters 個人頁網址 <code>matters.town/@___</code> 後面那段。
            </p>
          </div>
        </div>
      </section>

      <section
        id="badge"
        class="section section--paper"
        aria-labelledby="badge-title"
      >
        <div class="section__inner">
          <div class="badge-panel">
            <div class="badge-panel__visual" aria-hidden="true">
              <GrandBadge size={108} />
            </div>
            <div>
              <p class="eyebrow">{audiencePage.grandBadgeCopy.kicker}</p>
              <h2 id="badge-title">{audiencePage.grandBadgeCopy.title}</h2>
              <p>{audiencePage.grandBadgeCopy.body}</p>
              <p class="note-line">
                <a
                  href={shared.grandBadge.link.href}
                  target="_blank"
                  rel="noopener">{shared.grandBadge.link.label} →</a
                >
              </p>
            </div>
          </div>
        </div>
      </section>

      <section
        id="themes"
        class="section section--soft"
        aria-labelledby="themes-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">過去主題</p>
            <h2 id="themes-title">{audiencePage.pastThemesHeading}</h2>
            <p>
              每一期都像一本已經完成的小書。你可以從任何一個題目回去，找到下一次想寫的入口。
            </p>
          </header>

          <div class="theme-pager" data-theme-pager>
            {
              themesPages.map((page, pageIdx) => (
                <div
                  class="theme-grid theme-grid--landscape theme-pager__page"
                  data-page-index={pageIdx}
                  hidden={pageIdx !== 0}
                >
                  {page.map((theme) => (
                    <a
                      class="theme-card theme-card--landscape"
                      href={theme.announceHref}
                      target="_blank"
                      rel="noopener"
                    >
                      <div class="theme-card__media">
                        <img
                          src={assetSrc(theme.announceCover)}
                          alt=""
                          loading="lazy"
                        />
                      </div>
                      <div class="theme-card__body">
                        <span class="theme-card__meta">{theme.monthLabel} · {theme.series}</span>
                        <h3>{theme.name}</h3>
                        <p>
                          {theme.announceSummary && theme.announceSummary.length > 70
                            ? theme.announceSummary.slice(0, 70) + "…"
                            : theme.announceSummary}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              ))
            }

            <nav class="theme-pager__dots" aria-label="過去主題分頁切換">
              {
                themesPages.map((_, pageIdx) => (
                  <button
                    type="button"
                    class="theme-pager__dot"
                    data-page-target={pageIdx}
                    aria-label={`切換到第 ${pageIdx + 1} 頁過去主題`}
                    aria-current={pageIdx === 0 ? "true" : "false"}
                  />
                ))
              }
            </nav>

            <p class="theme-pager__more">
              <a class="button button--quiet" href={archiveHref}
                >看完整七日書歷來主題 →</a
              >
            </p>
          </div>
        </div>
      </section>

      <section
        id="lectures"
        class="section section--paper"
        aria-labelledby="lectures-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">名家講座</p>
            <h2 id="lectures-title">{audiencePage.lecturesHeading}</h2>
            <p>
              有逐字稿的講座，留下來就不只是一次活動，而是一篇可以反覆回看的寫作課。
            </p>
          </header>

          <p class="section__sublead">
            從 2024 年至今已邀請 {lectures.length} 位作家、詩人、研究者陪文友書寫。
            其中 {lectures.filter((l) => l.hasTranscript).length} 場有完整文字精華。
          </p>

          <div
            class="lecture-grid lecture-grid--dense"
            data-lecture-collapse
            data-collapsed-count="6"
          >
            {
              lectures.map((lecture, idx) => {
                return (
                  <article
                    class="lecture-card lecture-card--compact"
                    data-lecture-card-index={idx}
                    hidden={idx >= 6}
                  >
                    <div class="lecture-card__speaker lecture-card__speaker--text">
                      <strong>{lecture.speaker}</strong>
                      <span>
                        {lecture.role} · {lecture.theme}
                      </span>
                    </div>
                    {lecture.hasTranscript ? (
                      <>
                        <p class="lecture-card__excerpt">
                          {lecture.summary &&
                            (lecture.summary.length > 80
                              ? lecture.summary.slice(0, 80) + "…"
                              : lecture.summary)}
                        </p>
                        <a
                          class="lecture-card__link"
                          href={lecture.href}
                          target="_blank"
                          rel="noopener"
                        >
                          閱讀文字精華 →
                        </a>
                      </>
                    ) : (
                      <>
                        <p class="lecture-card__excerpt">{lecture.note}</p>
                        <span class="lecture-card__pill">講座記錄整理中</span>
                      </>
                    )}
                  </article>
                );
              })
            }
          </div>
          <p class="theme-pager__more">
            <button
              class="button button--quiet"
              type="button"
              data-lecture-expand
              aria-expanded="false"
            >
              <span data-lecture-expand-label
                >展開更多 {lectures.length - 6} 位講者 ↓</span
              >
            </button>
          </p>
        </div>
      </section>

      <section
        id="milestones"
        class="section section--soft"
        aria-labelledby="milestones-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">{audiencePage.milestonesHeading}</p>
            <h2 id="milestones-title">從第一期到 9,000 篇人生。</h2>
            <p>
              2024 春開始，每一個月一期，到 2026 年累積出來的時間軸。每個節點都連回 Matters 上的官方公告。
            </p>
          </header>

          <ol class="milestone-timeline">
            {
              milestones.map((m) => (
                <li>
                  <span class="milestone-timeline__date">{m.date}</span>
                  <div class="milestone-timeline__body">
                    <h3>{m.title}</h3>
                    <p>{m.body}</p>
                    <a
                      class="lecture-card__link"
                      href={m.href}
                      target="_blank"
                      rel="noopener"
                    >
                      閱讀公告 →
                    </a>
                  </div>
                  {m.image && (
                    <div class="milestone-timeline__media" aria-hidden="true">
                      <img src={assetSrc(m.image)} alt="" loading="lazy" />
                    </div>
                  )}
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section
        id="faq"
        class="section section--paper"
        aria-labelledby="faq-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">FAQ</p>
            <h2 id="faq-title">{audiencePage.faqHeading}</h2>
          </header>

          <div class="faq-list">
            {
              audienceFaq.map((item) => (
                <details>
                  <summary>{item.q}</summary>
                  <p>{item.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="cta-title">
        <div class="section__inner">
          <div class="cta-band">
            <h2 id="cta-title">{audiencePage.cta.headline}</h2>
            <p>{audiencePage.cta.body}</p>
            <div class="cta-band__actions">
              <button
                class="button button--primary"
                type="button"
                data-open-reminder
              >
                {audiencePage.cta.button}
              </button>
              <a
                class="button button--quiet"
                href={shared.joinHref}
                target="_blank"
                rel="noopener">直接加入本期</a
              >
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <span>Matters 七日書 · 自由寫</span>
      <a href={partnersHref}>機構合作入口 →</a>
    </footer>

    <dialog
      class="reminder-dialog"
      id="reminder-dialog"
      aria-labelledby="reminder-title"
      data-contact-email={contactEmail}
    >
      <div class="reminder-dialog__inner">
        <h2 id="reminder-title">獲得活動提醒郵件</h2>
        <p>留下 email，我們會在下一期七日書開放時通知你。</p>
        <form class="reminder-form" id="reminder-form">
          <label>
            Email
            <input
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="you@example.com"
            />
          </label>
          <div class="reminder-form__actions">
            <button
              class="button button--quiet"
              type="button"
              data-close-reminder>取消</button
            >
            <button class="button button--primary" type="submit"
              >送出提醒需求</button
            >
          </div>
        </form>
      </div>
    </dialog>
  </div>

  <script is:inline>
    // ── 過去主題分頁點點 ───────────────────────────────────────
    const pager = document.querySelector("[data-theme-pager]");
    if (pager) {
      const pages = pager.querySelectorAll(".theme-pager__page");
      const dots = pager.querySelectorAll("[data-page-target]");
      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const target = Number(dot.getAttribute("data-page-target"));
          pages.forEach((p, i) => {
            if (i === target) p.removeAttribute("hidden");
            else p.setAttribute("hidden", "");
          });
          dots.forEach((d, i) => {
            d.setAttribute("aria-current", i === target ? "true" : "false");
          });
        });
      });
    }

    // ── 名家講座 展開 / 收起 ─────────────────────────────────
    const lectureExpand = document.querySelector("[data-lecture-expand]");
    const lectureGrid = document.querySelector("[data-lecture-collapse]");
    if (lectureExpand && lectureGrid) {
      const initialL = Number(lectureGrid.getAttribute("data-collapsed-count") || "6");
      const lectureCards = lectureGrid.querySelectorAll("[data-lecture-card-index]");
      const totalL = lectureCards.length;
      const lecLabelEl = lectureExpand.querySelector("[data-lecture-expand-label]");
      let lExpanded = false;
      lectureExpand.addEventListener("click", () => {
        lExpanded = !lExpanded;
        lectureCards.forEach((c, i) => {
          if (lExpanded || i < initialL) c.removeAttribute("hidden");
          else c.setAttribute("hidden", "");
        });
        lectureExpand.setAttribute("aria-expanded", String(lExpanded));
        if (lecLabelEl) {
          lecLabelEl.textContent = lExpanded
            ? "收起，只看前 " + initialL + " 位 ↑"
            : "展開更多 " + (totalL - initialL) + " 位講者 ↓";
        }
      });
    }

    const dialog = document.getElementById("reminder-dialog");
    const form = document.getElementById("reminder-form");
    const contactEmail =
      dialog?.getAttribute("data-contact-email") || "freewrite@matters.town";
    const openButtons = document.querySelectorAll("[data-open-reminder]");
    const closeButtons = document.querySelectorAll("[data-close-reminder]");

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (dialog && typeof dialog.showModal === "function")
          dialog.showModal();
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => dialog?.close());
    });

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const email = String(formData.get("email") || "").trim();
      if (!email) return;
      const subject = encodeURIComponent("我想收到七日書活動提醒");
      const body = encodeURIComponent(
        `請將這個 email 加入七日書活動提醒名單：${email}`,
      );
      window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
      dialog?.close();
    });
  </script>

  <script is:inline>
    // ── 我的七日書足跡：用 Matters GraphQL 公開 API 查詢 user.articles，
    //    篩選有 "七日書" / "三日書" / "自由寫" / "兩廳院" / "情書"
    //    campaign 的，按 campaign 分組顯示。
    //    無登入、無紀錄、瀏覽器直連 Matters API。
    const passportForm = document.getElementById("passport-search");
    const passportResult = document.getElementById("passport-result");
    const passportInput = document.getElementById("passport-handle");
    const MATTERS_GQL = "https://server.matters.town/graphql";
    const MATTERS_BASE = "https://matters.town";
    const FREEWRITE_NEEDLE = ["七日書", "三日書", "自由寫", "情書", "兩廳院"];

    const escapeHtml = (s) =>
      String(s ?? "").replace(/[&<>"']/g, (c) => (
        { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]
      ));

    const fetchUserArticles = async (handle) => {
      const query = `query($userName: String!) {
        user(input: { userName: $userName }) {
          userName displayName avatar
          articles(input: { first: 100 }) {
            edges {
              node {
                shortHash slug title createdAt
                campaigns { campaign { shortHash name } }
              }
            }
          }
        }
      }`;
      const res = await fetch(MATTERS_GQL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ query, variables: { userName: handle } }),
      });
      const json = await res.json();
      if (json.errors) throw new Error(json.errors[0]?.message || "GraphQL error");
      return json.data.user;
    };

    const formatMonthLabel = (iso) => {
      if (!iso) return "";
      const [y, m] = iso.split("T")[0].split("-");
      return `${y} / ${Number(m)}`;
    };

    const renderResult = (user) => {
      if (!user) {
        passportResult.innerHTML = `
          <div class="passport-empty">
            <h3>找不到這位文友的 Matters 帳號</h3>
            <p>請確認帳號拼寫是否正確（@ 後面那段，例如 <code>mashbean</code>）。
            如果是新朋友，<a href="${escapeHtml(window.location.origin + window.location.pathname)}#current">先看看本月七日書題目</a>。</p>
          </div>`;
        return;
      }
      const articles = (user.articles?.edges || [])
        .map((e) => e.node)
        .filter((a) =>
          (a.campaigns || []).some((c) =>
            FREEWRITE_NEEDLE.some((n) => (c.campaign?.name || "").includes(n)),
          ),
        );

      if (!articles.length) {
        passportResult.innerHTML = `
          <div class="passport-empty">
            <h3>${escapeHtml(user.displayName)} 還沒在七日書留下足跡</h3>
            <p>查到 <a href="${MATTERS_BASE}/@${escapeHtml(user.userName)}" target="_blank" rel="noopener">@${escapeHtml(user.userName)}</a> 的 Matters 公開頁面，但沒看到七日書相關 campaign 的文章。</p>
            <p>歡迎現在加入：<a class="button button--primary" href="#current">看本月題目 →</a></p>
          </div>`;
        return;
      }

      // group by campaign shortHash
      const groups = new Map();
      articles.forEach((a) => {
        const c = (a.campaigns || []).find((c) =>
          FREEWRITE_NEEDLE.some((n) => (c.campaign?.name || "").includes(n)),
        )?.campaign;
        if (!c) return;
        if (!groups.has(c.shortHash))
          groups.set(c.shortHash, { campaign: c, articles: [] });
        groups.get(c.shortHash).articles.push(a);
      });

      // sort groups by latest article createdAt desc
      const sorted = [...groups.values()].sort((a, b) => {
        const da = Math.max(...a.articles.map((x) => +new Date(x.createdAt)));
        const db = Math.max(...b.articles.map((x) => +new Date(x.createdAt)));
        return db - da;
      });

      const totalArticles = articles.length;
      const totalCampaigns = sorted.length;
      const profileUrl = `${MATTERS_BASE}/@${user.userName}`;

      const groupHtml = sorted
        .map((g) => {
          const period = g.articles
            .map((a) => formatMonthLabel(a.createdAt))
            .filter(Boolean)[0];
          const eventUrl = `${MATTERS_BASE}/e/${g.campaign.shortHash}`;
          const articleList = g.articles
            .sort((a, b) => +new Date(a.createdAt) - +new Date(b.createdAt))
            .map(
              (a) => `
              <li>
                <a href="${MATTERS_BASE}/a/${escapeHtml(a.shortHash)}" target="_blank" rel="noopener">
                  ${escapeHtml(a.title)}
                </a>
                <span class="passport-article__date">${escapeHtml(a.createdAt.slice(0, 10))}</span>
              </li>`,
            )
            .join("");
          return `
            <article class="passport-group">
              <header class="passport-group__head">
                <div>
                  <p class="passport-group__meta">${escapeHtml(period || "")} · ${g.articles.length} 篇</p>
                  <h3>${escapeHtml(g.campaign.name)}</h3>
                </div>
                <a class="passport-group__link" href="${eventUrl}" target="_blank" rel="noopener">
                  看活動頁 →
                </a>
              </header>
              <ul class="passport-group__articles">${articleList}</ul>
            </article>`;
        })
        .join("");

      passportResult.innerHTML = `
        <div class="passport-found">
          <header class="passport-found__head">
            ${user.avatar ? `<img class="passport-found__avatar" src="${escapeHtml(user.avatar)}" alt="" />` : ""}
            <div>
              <p class="passport-found__name">
                ${escapeHtml(user.displayName)}
                <a href="${profileUrl}" target="_blank" rel="noopener">@${escapeHtml(user.userName)} →</a>
              </p>
              <p class="passport-found__stats">
                在 <strong>${totalCampaigns}</strong> 期七日書活動裡，留下 <strong>${totalArticles}</strong> 篇文章
              </p>
            </div>
          </header>
          <div class="passport-groups">${groupHtml}</div>
        </div>`;
    };

    const renderError = (msg) => {
      passportResult.innerHTML = `
        <div class="passport-empty">
          <h3>查詢沒成功</h3>
          <p>${escapeHtml(msg)}</p>
        </div>`;
    };

    const renderLoading = () => {
      passportResult.innerHTML = `
        <p class="passport-loading" aria-busy="true">正在向 Matters 詢問你的書寫足跡…</p>`;
    };

    passportForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const raw = (passportInput?.value || "").trim();
      if (!raw) return;
      const handle = raw.replace(/^@/, "").replace(/^https?:\/\/[^/]+\/@?/, "");
      if (!handle) return;
      renderLoading();
      try {
        const user = await fetchUserArticles(handle);
        renderResult(user);
      } catch (err) {
        renderError(err.message || String(err));
      }
    });
  </script>
</BaseLayout>
