---
import BaseLayout from "../layouts/BaseLayout.astro";
import GrandBadge from "../components/GrandBadge.astro";
import MattersWordmark from "../components/MattersWordmark.astro";
import SevenDayBookLogo from "../components/SevenDayBookLogo.astro";
import {
  allThemes,
  audienceFaq,
  audiencePage,
  contactEmail,
  currentIssue,
  milestones,
  pastThemes,
  shared,
} from "../data/seven-day-campaign";
import "../styles/seven-day-campaign.css";
import { withBase } from "../utils/paths";
import { EMAIL_REMINDER_ENDPOINT } from "../site.config";

const partnersHref = withBase(shared.partnersHref);
const archiveHref = withBase("museum/");
const assetSrc = (src?: string) => {
  if (!src) return "";
  return src.startsWith("http") ? src : withBase(src);
};
// 永久性 hero banner — 不綁本月活動，用 freewrite 自由寫的氣味博物館主視覺
const HERO_BANNER_SRC =
  "https://imagedelivery.net/kDRCweMmqLnTPNlbum-pYA/prod/campaignCover/fb1bd2c2-754d-493b-9750-352ef7fe27b7.png/w=1920,h=600,fit=cover";
// CC ys 提案第三階段：nav 從 6 項精簡到 3 項
//   - 大滿貫 / 過去主題 / 歷年里程 / FAQ 改為頁內 anchor，不放 nav-level
//   - 博物館 / 本月題目 / 洽談合作 三個是訪客真正會跳轉的目的地
const nav = [
  { href: archiveHref, label: "博物館" },
  { href: "#current", label: "本月題目" },
  { href: partnersHref, label: "洽談合作" },
];
const marqueeAvatars = [
  ...shared.avatarWall.slice(0, 22),
  ...shared.avatarWall.slice(0, 22),
];
// 全部過去主題 → 4 張一頁，提供分頁點點切換
const themesPerPage = 4;
const themesPages: typeof pastThemes[] = [];
for (let i = 0; i < pastThemes.length; i += themesPerPage) {
  themesPages.push(pastThemes.slice(i, i + themesPerPage));
}

---

<BaseLayout title="七日書" description={audiencePage.description}>
  <div class="campaign-page" data-page="audience">
    <header class="sitebar">
      <a
        class="sitebar__brand"
        href="https://matters.town"
        target="_blank"
        rel="noopener"
        aria-label="Matters · 七日書"
      >
        <MattersWordmark size={18} />
        <span class="sitebar__dot" aria-hidden="true">·</span>
        <SevenDayBookLogo size={20} title="七日書" />
      </a>

      <nav class="sitebar__nav" aria-label="頁面導覽">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <div class="sitebar__actions">
        <a class="button button--quiet" href={partnersHref}
          >{audiencePage.hero.secondaryLabel}</a
        >
        <a
          class="button button--primary"
          href={shared.joinHref}
          target="_blank"
          rel="noopener"
        >
          {audiencePage.hero.primaryLabel}
        </a>
      </div>
    </header>

    <main>
      <section class="hero hero--stacked" aria-labelledby="hero-title">
        <div class="hero__banner" aria-hidden="true">
          <img
            src={HERO_BANNER_SRC}
            alt=""
            loading="eager"
          />
        </div>
        <div class="hero__copy">
          <p class="eyebrow">{audiencePage.hero.eyebrow}</p>
          <h1 id="hero-title">{audiencePage.hero.headline}</h1>
          <p class="hero__lead">{audiencePage.hero.lead}</p>
          {/* CC ys #1: Hero 3 個 CTA → 1 個。
              data-hero-cta 由 inline script 在 page load 時根據 currentIssue.period
              判斷活動週狀態，動態替換文案與 href（活動週「加入本月寫作」、
              非活動週「看看大家寫了什麼」）。 */}
          <div class="hero__actions">
            <a
              class="button button--primary"
              data-hero-cta
              data-href-writing={shared.joinHref}
              data-href-browse={archiveHref}
              data-label-writing="加入本月寫作 →"
              data-label-browse="看看大家寫了什麼 →"
              href={shared.joinHref}
              target="_blank"
              rel="noopener">加入本月寫作 →</a
            >
          </div>
        </div>
      </section>

      <section
        id="stats"
        class="section section--paper"
        aria-labelledby="stats-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">此刻在寫</p>
            <h2 id="stats-title">有人和你在同一週，把生活寫下來。</h2>
            <p>先看見同行的人，題目才不會像一張孤單的待辦清單。</p>
          </header>

          <div class="metrics-grid">
            {
              audiencePage.stats.map((item) => (
                <article class="metric-card">
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                  <small>{item.note}</small>
                </article>
              ))
            }
          </div>

          <div class="avatar-marquee" aria-label="近期參與作者頭像">
            <div class="avatar-marquee__track">
              {
                marqueeAvatars.map((avatar) => (
                  <a
                    href={`https://matters.town/@${avatar.handle}`}
                    target="_blank"
                    rel="noopener"
                    title={avatar.name}
                  >
                    <img
                      src={assetSrc(avatar.src)}
                      alt={avatar.name}
                      loading="lazy"
                    />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <section
        id="museum-promo"
        class="museum-promo-dark"
        aria-labelledby="museum-promo-title"
      >
        <div
          class="museum-promo-bg"
          style={`background-image: url('${HERO_BANNER_SRC}');`}
          aria-hidden="true"
        ></div>
        <div class="museum-promo-overlay" aria-hidden="true"></div>

        <div class="museum-promo-inner">
          <div class="museum-promo-content">
            <p class="museum-promo-eyebrow">想看現在 · 想看過去</p>
            <h2 id="museum-promo-title">
              所有期數，都在<br/><span class="museum-promo-hl">七日書博物館</span>
            </h2>
            <p class="museum-promo-lead">
              本月正在進行的題目、{allThemes.length} 期歷來主題、3,200+ 位文友的足跡 ——
              都收進博物館。每張主視覺都連回 Matters 那場活動。
            </p>

            <ul class="museum-promo-stats" aria-label="博物館內容統計">
              <li>
                <strong>{allThemes.length}</strong>
                <span>期主題</span>
              </li>
              <li>
                <strong>3,200<sup>+</sup></strong>
                <span>位文友</span>
              </li>
              <li>
                <strong>9,000<sup>+</sup></strong>
                <span>篇人生</span>
              </li>
              <li>
                <strong>869</strong>
                <span>枚大滿貫</span>
              </li>
            </ul>

            <div class="museum-promo-actions">
              <a class="button museum-promo-cta" href={archiveHref}>
                <span>走進博物館</span>
                <span class="museum-promo-cta-arrow" aria-hidden="true">→</span>
              </a>
              <a class="museum-promo-link" href={`${archiveHref}#current-issue`}>
                看本月七題 →
              </a>
              <a class="museum-promo-link" href={`${archiveHref}#featured`}>
                看歷年精選 →
              </a>
            </div>
          </div>

          <ul class="museum-promo-thumbs" aria-label="近期七日書主視覺預覽">
            {
              allThemes
                .slice(-6)
                .reverse()
                .map((theme, i) => (
                  <li class="museum-promo-thumb" style={`--i: ${i}`}>
                    <a href={archiveHref} aria-label={`看 ${theme.name}`}>
                      <img
                        src={assetSrc(theme.announceCover)}
                        alt=""
                        loading="lazy"
                      />
                      <span class="museum-promo-thumb-label">
                        {theme.monthLabel}
                      </span>
                    </a>
                  </li>
                ))
            }
          </ul>
        </div>
      </section>

      <section
        id="badge"
        class="section section--paper"
        aria-labelledby="badge-title"
      >
        <div class="section__inner">
          <div class="badge-panel">
            <div class="badge-panel__visual" aria-hidden="true">
              <GrandBadge size={108} />
            </div>
            <div>
              <p class="eyebrow">{audiencePage.grandBadgeCopy.kicker}</p>
              <h2 id="badge-title">{audiencePage.grandBadgeCopy.title}</h2>
              <p>{audiencePage.grandBadgeCopy.body}</p>
              <p class="note-line">
                <a
                  href={shared.grandBadge.link.href}
                  target="_blank"
                  rel="noopener">{shared.grandBadge.link.label} →</a
                >
              </p>
            </div>
          </div>
        </div>
      </section>

      <section
        id="themes"
        class="section section--soft"
        aria-labelledby="themes-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">過去主題</p>
            <h2 id="themes-title">{audiencePage.pastThemesHeading}</h2>
            <p>
              每一期都像一本已經完成的小書。你可以從任何一個題目回去，找到下一次想寫的入口。
            </p>
          </header>

          <div class="theme-pager" data-theme-pager>
            {
              themesPages.map((page, pageIdx) => (
                <div
                  class="theme-grid theme-grid--landscape theme-pager__page"
                  data-page-index={pageIdx}
                  hidden={pageIdx !== 0}
                >
                  {page.map((theme) => (
                    <a
                      class="theme-card theme-card--landscape"
                      href={theme.announceHref}
                      target="_blank"
                      rel="noopener"
                    >
                      <div class="theme-card__media">
                        <img
                          src={assetSrc(theme.announceCover)}
                          alt=""
                          loading="lazy"
                        />
                      </div>
                      <div class="theme-card__body">
                        <span class="theme-card__meta">{theme.monthLabel} · {theme.series}</span>
                        <h3>{theme.name}</h3>
                        <p>
                          {theme.announceSummary && theme.announceSummary.length > 70
                            ? theme.announceSummary.slice(0, 70) + "…"
                            : theme.announceSummary}
                        </p>
                      </div>
                    </a>
                  ))}
                </div>
              ))
            }

            <nav class="theme-pager__dots" aria-label="過去主題分頁切換">
              {
                themesPages.map((_, pageIdx) => (
                  <button
                    type="button"
                    class="theme-pager__dot"
                    data-page-target={pageIdx}
                    aria-label={`切換到第 ${pageIdx + 1} 頁過去主題`}
                    aria-current={pageIdx === 0 ? "true" : "false"}
                  />
                ))
              }
            </nav>

            <div class="theme-pager__more">
              <a class="button button--quiet" href={archiveHref}
                >看完整七日書歷來主題 →</a
              >
            </div>
          </div>
        </div>
      </section>

      <!-- 名家講座 已搬到 /museum 「歷年精選文章」下方 -->


      <section
        id="milestones"
        class="section section--soft"
        aria-labelledby="milestones-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">{audiencePage.milestonesHeading}</p>
            <h2 id="milestones-title">從第一期到 9,000 篇人生。</h2>
            <p>
              2024 春開始，每一個月一期，到 2026 年累積出來的時間軸。每個節點都連回 Matters 上的官方公告。
            </p>
          </header>

          <ol class="milestone-timeline">
            {
              milestones.map((m) => (
                <li>
                  <span class="milestone-timeline__date">{m.date}</span>
                  <div class="milestone-timeline__body">
                    <h3>{m.title}</h3>
                    <p>{m.body}</p>
                    <a
                      class="lecture-card__link"
                      href={m.href}
                      target="_blank"
                      rel="noopener"
                    >
                      閱讀公告 →
                    </a>
                  </div>
                  {m.image && (
                    <div class="milestone-timeline__media" aria-hidden="true">
                      <img src={assetSrc(m.image)} alt="" loading="lazy" />
                    </div>
                  )}
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section
        id="faq"
        class="section section--paper"
        aria-labelledby="faq-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">FAQ</p>
            <h2 id="faq-title">{audiencePage.faqHeading}</h2>
          </header>

          <div class="faq-list">
            {
              audienceFaq.map((item) => (
                <details>
                  <summary>{item.q}</summary>
                  <p>{item.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      {/* CC ys #7: 最終 CTA 雙態切換
          - 活動週：「本月七日書進行中，還有 X 天」+ 加入按鈕
          - 非活動週：「下一期 M 月 D 日開始」+ inline email subscribe（不再用 modal）
          inline script 在 load 時 detect currentIssue.period 切換顯示。
          email submit 走原本 reminder-dialog 的 Apps Script endpoint，邏輯共用。 */}
      <section
        class="section section--cta"
        id="next-up"
        aria-labelledby="cta-title"
        data-current-period={currentIssue.period}
        data-event-href={shared.joinHref}
        data-current-days-left=""
      >
        <div class="section__inner">
          <div class="cta-band cta-band--dual">
            {/* 活動週版（預設隱藏，由 JS 切換） */}
            <div class="cta-band__state cta-band__state--writing" hidden>
              <h2 id="cta-title-writing">本月七日書進行中</h2>
              <p>
                還有 <strong data-days-left>—</strong> 天，現在加入還來得及。
              </p>
              <div class="cta-band__actions">
                <a
                  class="button button--primary"
                  href={shared.joinHref}
                  target="_blank"
                  rel="noopener">加入本月寫作 →</a
                >
                <a class="button button--quiet" href={archiveHref}
                  >走進博物館看歷年作品</a
                >
              </div>
            </div>

            {/* 非活動週版（預設顯示） */}
            <div class="cta-band__state cta-band__state--reminder">
              <h2 id="cta-title">{audiencePage.cta.headline}</h2>
              <p>
                <span data-next-issue-text>{audiencePage.cta.body}</span>
              </p>
              <form
                class="cta-reminder-form"
                id="cta-reminder-form"
                novalidate
                data-endpoint={EMAIL_REMINDER_ENDPOINT}
              >
                <label class="cta-reminder-form__label">
                  <span class="sr-only">Email</span>
                  <input
                    name="email"
                    type="email"
                    autocomplete="email"
                    required
                    placeholder="留下 email，下一期開放通知你"
                  />
                </label>
                <button class="button button--primary" type="submit"
                  >訂閱提醒</button
                >
                <a class="button button--quiet" href={archiveHref}
                  >先看歷年作品</a
                >
              </form>
              <p
                class="cta-reminder-form__status"
                id="cta-reminder-status"
                role="status"
                aria-live="polite"
              ></p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <span>Matters 七日書 · 自由寫</span>
      <a href={partnersHref}>機構合作入口 →</a>
    </footer>

    <dialog
      class="reminder-dialog"
      id="reminder-dialog"
      aria-labelledby="reminder-title"
      data-contact-email={contactEmail}
      data-endpoint={EMAIL_REMINDER_ENDPOINT}
    >
      <div class="reminder-dialog__inner">
        <h2 id="reminder-title">獲得活動提醒郵件</h2>
        <p>留下 email，我們會在下一期七日書開放時通知你。</p>
        <form class="reminder-form" id="reminder-form" novalidate>
          <label>
            Email
            <input
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="you@example.com"
            />
          </label>
          <p class="reminder-form__status" id="reminder-status" role="status" aria-live="polite"></p>
          <div class="reminder-form__actions">
            <button
              class="button button--quiet"
              type="button"
              data-close-reminder>取消</button
            >
            <button class="button button--primary" type="submit" id="reminder-submit"
              >送出提醒需求</button
            >
          </div>
        </form>
      </div>
    </dialog>
  </div>

  <script is:inline>
    // ── 過去主題分頁點點 ───────────────────────────────────────
    const pager = document.querySelector("[data-theme-pager]");
    if (pager) {
      const pages = pager.querySelectorAll(".theme-pager__page");
      const dots = pager.querySelectorAll("[data-page-target]");
      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const target = Number(dot.getAttribute("data-page-target"));
          pages.forEach((p, i) => {
            if (i === target) p.removeAttribute("hidden");
            else p.setAttribute("hidden", "");
          });
          dots.forEach((d, i) => {
            d.setAttribute("aria-current", i === target ? "true" : "false");
          });
        });
      });
    }

    // 名家講座 展開 / 收起 → 已搬到 /museum

    // CC ys #1 + #7: 活動週狀態偵測，動態切換 hero CTA 與 final CTA section
    //
    // 規則：
    //   - 活動週 = 今天落在 currentIssue.period 範圍內（例如 "2026/5/4 - 2026/5/11"）
    //   - 非活動週 = 否
    //
    // 影響元件：
    //   - [data-hero-cta]：切換 label + href（活動週用 "加入本月寫作" / 非活動週用 "看看大家寫了什麼"）
    //   - #next-up section：兩種 state，活動週顯示倒數天數 + CTA、非活動週顯示 email 訂閱表單
    const ctaSection = document.getElementById("next-up");
    const periodStr = ctaSection?.getAttribute("data-current-period") || "";
    const isWritingWeek = (() => {
      if (!periodStr) return false;
      const [startStr, endStr] = periodStr.split(/\s*-\s*/);
      if (!startStr || !endStr) return false;
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const parseDate = (s) => {
        // 容錯解析 "2026/5/4" 或 "2026-05-04"
        const parts = s.trim().split(/[\/\-]/).map(Number);
        return new Date(parts[0], parts[1] - 1, parts[2]);
      };
      const start = parseDate(startStr);
      const end = parseDate(endStr);
      end.setHours(23, 59, 59, 999); // 活動最後一天含整天
      return today >= start && today <= end;
    })();

    // Hero CTA 切換
    const heroCta = document.querySelector("[data-hero-cta]");
    if (heroCta) {
      if (isWritingWeek) {
        heroCta.textContent = heroCta.getAttribute("data-label-writing") || heroCta.textContent;
        heroCta.setAttribute("href", heroCta.getAttribute("data-href-writing") || "#");
      } else {
        heroCta.textContent = heroCta.getAttribute("data-label-browse") || heroCta.textContent;
        heroCta.setAttribute("href", heroCta.getAttribute("data-href-browse") || "#");
        heroCta.removeAttribute("target"); // 內部連結不開新分頁
        heroCta.removeAttribute("rel");
      }
    }

    // Final CTA section 切換 + 算剩餘天數
    if (ctaSection) {
      const writingBlock = ctaSection.querySelector(".cta-band__state--writing");
      const reminderBlock = ctaSection.querySelector(".cta-band__state--reminder");
      if (isWritingWeek && writingBlock && reminderBlock) {
        writingBlock.hidden = false;
        reminderBlock.hidden = true;
        // 算剩餘天數
        const [, endStr] = periodStr.split(/\s*-\s*/);
        const parts = endStr.trim().split(/[\/\-]/).map(Number);
        const end = new Date(parts[0], parts[1] - 1, parts[2], 23, 59, 59, 999);
        const today = new Date();
        const daysLeft = Math.max(0, Math.ceil((end - today) / (1000 * 60 * 60 * 24)));
        const daysEl = writingBlock.querySelector("[data-days-left]");
        if (daysEl) daysEl.textContent = String(daysLeft);
      }
      // else: 維持預設（reminder 顯示、writing 隱藏）
    }

    // CTA section inline reminder form (非活動週 email 訂閱)
    const ctaForm = document.getElementById("cta-reminder-form");
    const ctaStatusEl = document.getElementById("cta-reminder-status");
    if (ctaForm) {
      const ctaEndpoint = ctaForm.getAttribute("data-endpoint") || "";
      const setCtaStatus = (msg, kind) => {
        if (!ctaStatusEl) return;
        ctaStatusEl.textContent = msg || "";
        ctaStatusEl.dataset.kind = kind || "";
      };
      ctaForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const fd = new FormData(ctaForm);
        const email = String(fd.get("email") || "").trim();
        if (!email || !/.+@.+\..+/.test(email)) {
          setCtaStatus("請輸入有效的 email", "error");
          return;
        }
        const submit = ctaForm.querySelector("button[type=submit]");
        submit && (submit.disabled = true);
        setCtaStatus("送出中…", "loading");
        try {
          await fetch(ctaEndpoint, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "text/plain;charset=utf-8" },
            body: JSON.stringify({
              email,
              source: "landing-cta-inline",
              userAgent: navigator.userAgent,
              referrer: document.referrer || "",
            }),
          });
          setCtaStatus("✓ 已收到！下一期開放時會寄通知給你。", "success");
          ctaForm.reset();
        } catch (err) {
          setCtaStatus("送出失敗，請稍後再試。", "error");
          submit && (submit.disabled = false);
        }
      });
    }

    const dialog = document.getElementById("reminder-dialog");
    const form = document.getElementById("reminder-form");
    const statusEl = document.getElementById("reminder-status");
    const submitBtn = document.getElementById("reminder-submit");
    const endpoint = dialog?.getAttribute("data-endpoint") || "";
    const contactEmail =
      dialog?.getAttribute("data-contact-email") || "freewrite@matters.town";
    const openButtons = document.querySelectorAll("[data-open-reminder]");
    const closeButtons = document.querySelectorAll("[data-close-reminder]");

    const setStatus = (msg, kind) => {
      if (!statusEl) return;
      statusEl.textContent = msg || "";
      statusEl.dataset.kind = kind || "";
    };

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setStatus("", "");
        if (form) form.reset();
        if (submitBtn) submitBtn.disabled = false;
        if (dialog && typeof dialog.showModal === "function")
          dialog.showModal();
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => dialog?.close());
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const email = String(formData.get("email") || "").trim();
      if (!email || !/.+@.+\..+/.test(email)) {
        setStatus("請輸入有效的 email", "error");
        return;
      }
      if (!endpoint) {
        // Fallback：endpoint 沒設好就回到 mailto
        const subject = encodeURIComponent("我想收到七日書活動提醒");
        const body = encodeURIComponent(`請將這個 email 加入七日書活動提醒名單：${email}`);
        window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
        dialog?.close();
        return;
      }
      submitBtn && (submitBtn.disabled = true);
      setStatus("送出中…", "loading");
      try {
        // text/plain 避開 CORS preflight (Apps Script Web App 不接 preflight)
        await fetch(endpoint, {
          method: "POST",
          mode: "no-cors", // Apps Script doPost 不回 CORS header；no-cors 不讀 response 也 OK
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: JSON.stringify({
            email,
            source: "landing-reminder",
            userAgent: navigator.userAgent,
            referrer: document.referrer || "",
          }),
        });
        setStatus("✓ 已收到！下一期開放時會寄通知給你。", "success");
        setTimeout(() => dialog?.close(), 1800);
      } catch (err) {
        setStatus("送出失敗，請稍後再試或直接寄信給我們。", "error");
        submitBtn && (submitBtn.disabled = false);
      }
    });
  </script>

</BaseLayout>
