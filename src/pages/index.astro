---
import BaseLayout from "../layouts/BaseLayout.astro";
import GrandBadge from "../components/GrandBadge.astro";
import MattersWordmark from "../components/MattersWordmark.astro";
import SevenDayBookLogo from "../components/SevenDayBookLogo.astro";
import {
  allThemes,
  audienceFaq,
  audiencePage,
  contactEmail,
  currentIssue,
  milestones,
  shared,
} from "../data/seven-day-campaign";
import { communityQuotes } from "../data/community-quotes";
import {
  totalUniqueGrandSlamWinners,
  totalUniqueAwardWinners,
  totalRegistrations,
  totalUniqueAuthors,
  totalArticles,
} from "../data/freewrite-marathoners";
import { freewriteIssues } from "../data/freewrite-prompts";
import "../styles/seven-day-campaign.css";
import { withBase } from "../utils/paths";
import { EMAIL_REMINDER_ENDPOINT } from "../site.config";

const partnersHref = withBase(shared.partnersHref);
const archiveHref = withBase("museum/");
const assetSrc = (src?: string) => {
  if (!src) return "";
  return src.startsWith("http") ? src : withBase(src);
};
// 永久性 hero banner — 不綁本月活動，用 freewrite 自由寫的氣味博物館主視覺
const HERO_BANNER_SRC =
  "https://imagedelivery.net/kDRCweMmqLnTPNlbum-pYA/prod/campaignCover/fb1bd2c2-754d-493b-9750-352ef7fe27b7.png/w=1920,h=600,fit=cover";
// CC ys 提案第三階段：nav 從 6 項精簡到 3 項
//   - 大滿貫 / 過去主題 / 歷年里程 / FAQ 改為頁內 anchor，不放 nav-level
//   - 博物館 / 本月題目 / 洽談合作 三個是訪客真正會跳轉的目的地
const nav = [
  { href: archiveHref, label: "博物館" },
  { href: "#current", label: "本月題目" },
  { href: partnersHref, label: "洽談合作" },
];
const marqueeAvatars = [
  ...shared.avatarWall.slice(0, 22),
  ...shared.avatarWall.slice(0, 22),
];
// 「過去主題」分頁切換已退役 — 改為 §Section 3 題目庫 (#prompts) 用 details accordion
// 顯示完整 24 期 156 題，資料來自 src/data/freewrite-prompts.ts

---

<BaseLayout title="七日書" description={audiencePage.description}>
  <div class="campaign-page" data-page="audience">
    <header class="sitebar">
      <a
        class="sitebar__brand"
        href="https://matters.town"
        target="_blank"
        rel="noopener"
        aria-label="Matters · 七日書"
      >
        <MattersWordmark size={18} />
        <span class="sitebar__dot" aria-hidden="true">·</span>
        <SevenDayBookLogo size={20} title="七日書" />
      </a>

      <nav class="sitebar__nav" aria-label="頁面導覽">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <div class="sitebar__actions">
        <a class="button button--quiet" href={partnersHref}
          >{audiencePage.hero.secondaryLabel}</a
        >
        <a
          class="button button--primary"
          href={shared.joinHref}
          target="_blank"
          rel="noopener"
        >
          {audiencePage.hero.primaryLabel}
        </a>
      </div>
    </header>

    <main>
      <section class="hero hero--stacked" aria-labelledby="hero-title">
        <div class="hero__banner" aria-hidden="true">
          <img
            src={HERO_BANNER_SRC}
            alt=""
            loading="eager"
          />
        </div>
        <div class="hero__copy">
          <p class="eyebrow">{audiencePage.hero.eyebrow}</p>
          <h1 id="hero-title">{audiencePage.hero.headline}</h1>
          <p class="hero__lead">{audiencePage.hero.lead}</p>
          {/* v2 改版：hero CTA 永遠是「加入本月寫作」連到本月活動頁 (currentIssue.eventHref)
              移除之前 dual-state JS 切換（活動週/非活動週兩種文案） */}
          <div class="hero__actions">
            <a
              class="button button--primary"
              href={currentIssue.eventHref}
              target="_blank"
              rel="noopener">加入本月寫作 →</a
            >
          </div>
        </div>
      </section>

      {/* §Section 2 本月主題（v2 改版）— 本月七日書的主題 + 7 道題目 + CTA
          資料：currentIssue (src/data/seven-day-campaign.ts)
          注意：Matters event 頁面目前沒有 deep-link 到單天的 URL 結構，
          所以每道題目卡片連的還是整個活動頁 (currentIssue.eventHref)，
          讓使用者進去自己找對應天的 tab。 */}
      <section
        id="current"
        class="section section--paper"
        aria-labelledby="current-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">本月七日書 · {currentIssue.period}</p>
            <h2 id="current-title">{currentIssue.title}</h2>
            <p>{currentIssue.summary}</p>
          </header>

          <ol class="current-prompts">
            {
              currentIssue.prompts.map((p) => (
                <li class={`current-prompts__item current-prompts__item--${p.state}`}>
                  <a
                    class="current-prompts__link"
                    href={currentIssue.eventHref}
                    target="_blank"
                    rel="noopener"
                  >
                    <span class="current-prompts__day">{p.day}</span>
                    <span class="current-prompts__date">{p.date}</span>
                    <h3 class="current-prompts__title">{p.title}</h3>
                    <p class="current-prompts__prompt">{p.prompt}</p>
                    <span class="current-prompts__arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))
            }
          </ol>

          <div class="current-prompts__cta">
            <a
              class="button button--primary"
              href={currentIssue.eventHref}
              target="_blank"
              rel="noopener"
            >加入本月寫作 →</a>
            <a class="button button--quiet" href={currentIssue.announcementHref} target="_blank" rel="noopener"
              >讀本期主題公告 →</a
            >
          </div>
        </div>
      </section>

      {/* §Section 3 (原 Section 2a): 社群溫度 — 9 句精華 quote
          來源：scripts/curate-community-quotes.mjs 從 531 篇精選文做文本評分挑出
          重跑：node scripts/curate-community-quotes.mjs --write */}
      <section
        id="voices"
        class="section section--paper"
        aria-labelledby="voices-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">社群的聲音</p>
            <h2 id="voices-title">先聽聽他們在寫什麼。</h2>
            <p>八句來自過往七日書的精選句子，每一句都能點開看完整篇。</p>
          </header>

          <ul class="voices-grid">
            {communityQuotes.map((q) => (
              <li class="voice-card">
                <blockquote class="voice-card__text">
                  「{q.text}」
                </blockquote>
                <a
                  class="voice-card__attr"
                  href={`https://matters.town/a/${q.articleHash}`}
                  target="_blank"
                  rel="noopener"
                >
                  {q.avatar && (
                    <img
                      class="voice-card__avatar"
                      src={q.avatar}
                      alt=""
                      loading="lazy"
                    />
                  )}
                  <span class="voice-card__author">{q.author}</span>
                  <span class="voice-card__campaign">{q.campaignLabel}</span>
                </a>
              </li>
            ))}
          </ul>

          <p class="voices-grid__more">
            還有 <strong>531</strong> 篇精選作品在
            <a href={archiveHref}>博物館</a> 裡 →
          </p>
        </div>
      </section>

      {/* CC ys §Section 2b: 數字帶 — 精簡，原 #stats 拿掉「大滿貫」（搬到 §5），
          只留 期數 / 參與人次 / 篇數 三個數字 + avatar marquee */}
      <section
        id="stats"
        class="section section--paper"
        aria-labelledby="stats-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">兩年累積</p>
            <h2 id="stats-title">有人和你在同一週，把生活寫下來。</h2>
            <p>下面是這個社群這兩年寫出來的量。</p>
          </header>

          <div class="metrics-grid">
            {audiencePage.stats
              .filter((s) => !/大滿貫/.test(s.label))
              .map((item) => (
                <article class="metric-card">
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                  <small>{item.note}</small>
                </article>
              ))}
          </div>

          <div class="avatar-marquee" aria-label="近期參與作者頭像">
            <div class="avatar-marquee__track">
              {
                marqueeAvatars.map((avatar) => (
                  <a
                    href={`https://matters.town/@${avatar.handle}`}
                    target="_blank"
                    rel="noopener"
                    title={avatar.name}
                  >
                    <img
                      src={assetSrc(avatar.src)}
                      alt={avatar.name}
                      loading="lazy"
                    />
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      {/* CC ys §Section 4: 怎麼運作 — 機制 chip + 實例細節
          回應 ys 提案「每月一週 / 七天七道題目 / 集體一起完成」並補實例。 */}
      <section
        id="how"
        class="section"
        aria-labelledby="how-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">怎麼參與</p>
            <h2 id="how-title">每月一次，七天寫成一本小書。</h2>
            <p>免費報名、完全公開；不寫批改、只看書寫節奏。</p>
          </header>

          <ol class="how-grid">
            <li class="how-chip">
              <span class="how-chip__step">01</span>
              <h3>每月底開放報名</h3>
              <p>
                每月 25 號公布下一期主題，月底前到<a href={currentIssue.eventHref} target="_blank" rel="noopener">活動頁</a>報名。報名後活動頁進度條會記錄你的七天寫作。
              </p>
            </li>
            <li class="how-chip">
              <span class="how-chip__step">02</span>
              <h3>七天，七道題目</h3>
              <p>
                每天一道題目，總共七題。當天題目要當天寫；
                晚一天才寫也算（過了一週就只算「參與」不算「大滿貫」）。
              </p>
            </li>
            <li class="how-chip">
              <span class="how-chip__step">03</span>
              <h3>FreeWrite 精神</h3>
              <p>
                自由書寫不批改自己；先讓字流出來、回頭再改。
              </p>
            </li>
            <li class="how-chip how-chip--badge">
              <span class="how-chip__step-row">
                <span class="how-chip__step">04</span>
                <span class="how-chip__badge-mini" aria-hidden="true">
                  <GrandBadge size={28} />
                </span>
              </span>
              <h3>{audiencePage.grandBadgeCopy.title}</h3>
              <p>{audiencePage.grandBadgeCopy.body}</p>
              <p class="how-chip__link">
                <a
                  href={shared.grandBadge.link.href}
                  target="_blank"
                  rel="noopener">{shared.grandBadge.link.label} →</a
                >
              </p>
            </li>
          </ol>
        </div>
      </section>

      {/* §Section 6 (v2 改版): 題目庫
          - 從新到舊（S25 在最上、預設展開）
          - 每期標題加大字
          - 每期 summary 旁加「參與寫作」button 連到該期 matters.town 活動頁
          資料：src/data/freewrite-prompts.ts (24 期 156 題，scrape 自 Matters 公告)
          重抓：node scripts/scrape-campaign-prompts.mjs --write */}
      {/* series 編號 → matters.town event shortHash 對照（5-25 期；1-4 期早於 campaign 模組無 hash） */}
      {(() => {
        // themes.json series → matters.town event hash 對照
        // 注意：themes 漏「山海塢三日書」這期 (obs id 6)，所以 themes S6 = obs id 7
        // 從 S6 之後全 off-by-one。Source of truth：scripts/import-awards.mjs / museum.astro
        const SERIES_TO_EVENT = {
          S5: "ia800figcq9y",   // obs 5 成長軌跡
          S6: "scx3f16y37v6",   // obs 7 島嶼精神
          S7: "8t5liudbtpup",   // obs 8 物的體系
          S8: "eqsfuc3qph6u",   // obs 9 我的（不）完美人生
          S9: "x4rv6dwgk68o",   // obs 10 人間鬼故事
          S10: "f7rpyecg32mg",  // obs 11 我的家庭故事
          S11: "4nqnizsygmcn",  // obs 12 書寫地方
          S12: "26uhbm3uh6rg",  // obs 13 人生的靈魂提問
          S13: "efkk0l9hcg96",  // obs 14 What If
          S14: "h2ya9xxjubd2",  // obs 15 長女症候群
          S15: "5zhf2bpty274",  // obs 16 兩廳院 8 月
          S16: "rt04oolqbexh",  // obs 17 兩廳院 9 月
          S17: "owt3jxplay6z",  // obs 18 曖昧時刻
          S18: "3uskpxsbzmz5",  // obs 19 重構生活
          S19: "ox9fmcz6zxxj",  // obs 20 說聲告別
          S20: "nqbeo3cdn585",  // obs 21 衣櫥裡的自我
          S21: "4v5mndkbz44v",  // obs 22 數位雲端的我
          S22: "q48dv6ve4g2m",  // obs 23 我的人生帳本
          S23: "aiafcgbu89p2",  // obs 24 氣味博物館
          S24: "wem6xy6u7okv",  // obs 25 我的職場人格
          S25: "nxy5zqcjs7lt",  // obs 26 無用之用
          S26: "a6weg482vsxe",  // obs 27 集體記憶 (current)
        };
        const issuesReversed = [...freewriteIssues].reverse();
        return (
          <section
            id="prompts"
            class="section section--soft"
            aria-labelledby="prompts-title"
          >
            <div class="section__inner">
              <header class="section__header">
                <p class="eyebrow">題目庫</p>
                <h2 id="prompts-title">{audiencePage.pastThemesHeading}</h2>
                <p>
                  {freewriteIssues.length} 期共 {freewriteIssues.reduce((s, i) => s + i.prompts.length, 0)} 道題目，從新到舊。點開期數看每天題目，按「參與寫作」直接到 Matters 活動頁。
                </p>
              </header>

              {/* v3: 預設展開最新一期、但只顯示前 5 個 entry；
                  其餘 hidden + 「查看更多」button 展開
                  prompt 內七天改成單欄 + 加大行距，閱讀友善 */}
              <ol class="prompt-issue-list" data-prompt-list data-initial="5">
                {issuesReversed.map((issue, idx) => {
                  const themeMeta = allThemes.find((t) => t.series === issue.series);
                  const oneLine = themeMeta?.announceSummary
                    ? (themeMeta.announceSummary.length > 60
                        ? themeMeta.announceSummary.slice(0, 60) + "…"
                        : themeMeta.announceSummary)
                    : "";
                  const eventHash = SERIES_TO_EVENT[issue.series];
                  const eventHref = eventHash
                    ? `https://matters.town/e/${eventHash}`
                    : issue.announceHref;
                  return (
                    <li
                      class="prompt-issue"
                      data-prompt-item={idx}
                      hidden={idx >= 5}
                    >
                      <details class="prompt-issue__details" open={idx === 0}>
                        <summary class="prompt-issue__summary">
                          <span class="prompt-issue__series">第 {issue.series.replace(/^S/, "")} 期</span>
                          <span class="prompt-issue__name">
                            <strong>{issue.name.replace(/^七日書[｜：]/, "")}</strong>
                            {oneLine && <em>{oneLine}</em>}
                          </span>
                          <span class="prompt-issue__month">{issue.monthLabel}</span>
                          <a
                            class="button button--soft prompt-issue__join"
                            href={eventHref}
                            target="_blank"
                            rel="noopener"
                            onclick="event.stopPropagation()"
                          >參與寫作 →</a>
                        </summary>
                        <div class="prompt-issue__days-wrap">
                          <ol class="prompt-issue__days">
                            {issue.prompts.map((p) => (
                              <li class="prompt-day">
                                <span class="prompt-day__label">{p.day}</span>
                                <div class="prompt-day__body">
                                  <h4>{p.title}</h4>
                                  {p.prompt !== p.title && <p>{p.prompt}</p>}
                                </div>
                              </li>
                            ))}
                          </ol>
                          <a
                            class="prompt-issue__source"
                            href={issue.announceHref}
                            target="_blank"
                            rel="noopener"
                          >到 Matters 看完整公告 →</a>
                        </div>
                      </details>
                    </li>
                  );
                })}
              </ol>

              {issuesReversed.length > 5 && (
                <div class="prompt-issue-list__more">
                  <button
                    class="button button--quiet"
                    type="button"
                    data-prompt-expand
                    aria-expanded="false"
                  >
                    <span data-prompt-expand-label
                      >查看更多（還有 {issuesReversed.length - 5} 期）↓</span
                    >
                  </button>
                </div>
              )}
            </div>
          </section>
        );
      })()}

      <section
        id="museum-promo"
        class="museum-promo-dark"
        aria-labelledby="museum-promo-title"
      >
        <div
          class="museum-promo-bg"
          style={`background-image: url('${HERO_BANNER_SRC}');`}
          aria-hidden="true"
        ></div>
        <div class="museum-promo-overlay" aria-hidden="true"></div>

        <div class="museum-promo-inner">
          <div class="museum-promo-content">
            <p class="museum-promo-eyebrow">給已參與的文友</p>
            <h2 id="museum-promo-title">
              <span class="museum-promo-hl">七日書博物館</span>
            </h2>
            <p class="museum-promo-lead">
              如果你已經是七日書作者，進入博物館，找到自己的寫作展廳，製作專屬小書。
            </p>

            <div class="museum-promo-actions">
              <a class="button museum-promo-cta" href={archiveHref}>
                <span>走進博物館</span>
                <span class="museum-promo-cta-arrow" aria-hidden="true">→</span>
              </a>
              <a class="museum-promo-link" href={`${archiveHref}#featured`}>
                看歷年精選 →
              </a>
            </div>
          </div>

          <ul class="museum-promo-thumbs" aria-label="近期七日書主視覺預覽">
            {
              allThemes
                .slice(-6)
                .reverse()
                .map((theme, i) => (
                  <li class="museum-promo-thumb" style={`--i: ${i}`}>
                    <a href={archiveHref} aria-label={`看 ${theme.name}`}>
                      <img
                        src={assetSrc(theme.announceCover)}
                        alt=""
                        loading="lazy"
                      />
                      <span class="museum-promo-thumb-label">
                        {theme.monthLabel}
                      </span>
                    </a>
                  </li>
                ))
            }
          </ul>
        </div>
      </section>

      <!-- v2 改版：移除 #milestones section（總篇數已在 #stats 顯示，避免重複）
           名家講座已搬到 /museum 「歷年精選文章」下方 -->


      <section
        id="faq"
        class="section section--paper"
        aria-labelledby="faq-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">FAQ</p>
            <h2 id="faq-title">{audiencePage.faqHeading}</h2>
          </header>

          <div class="faq-list">
            {
              audienceFaq.map((item) => (
                <details>
                  <summary>{item.q}</summary>
                  <p>{item.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      {/* CC ys #7: 最終 CTA 雙態切換
          - 活動週：「本月七日書進行中，還有 X 天」+ 加入按鈕
          - 非活動週：「下一期 M 月 D 日開始」+ inline email subscribe（不再用 modal）
          inline script 在 load 時 detect currentIssue.period 切換顯示。
          email submit 走原本 reminder-dialog 的 Apps Script endpoint，邏輯共用。 */}
      <section
        class="section section--cta"
        id="next-up"
        aria-labelledby="cta-title"
        data-current-period={currentIssue.period}
        data-event-href={shared.joinHref}
        data-current-days-left=""
      >
        <div class="section__inner">
          <div class="cta-band cta-band--dual">
            {/* 活動週版（預設隱藏，由 JS 切換） */}
            <div class="cta-band__state cta-band__state--writing" hidden>
              <h2 id="cta-title-writing">本月七日書進行中</h2>
              <p>
                還有 <strong data-days-left>—</strong> 天，現在加入還來得及。
              </p>
              <div class="cta-band__actions">
                <a
                  class="button button--primary"
                  href={shared.joinHref}
                  target="_blank"
                  rel="noopener">加入本月寫作 →</a
                >
                <a class="button button--quiet" href={archiveHref}
                  >走進博物館看歷年作品</a
                >
              </div>
            </div>

            {/* 非活動週版（預設顯示） */}
            <div class="cta-band__state cta-band__state--reminder">
              <h2 id="cta-title">{audiencePage.cta.headline}</h2>
              <p>
                <span data-next-issue-text>{audiencePage.cta.body}</span>
              </p>
              <form
                class="cta-reminder-form"
                id="cta-reminder-form"
                novalidate
                data-endpoint={EMAIL_REMINDER_ENDPOINT}
              >
                <label class="cta-reminder-form__label">
                  <span class="sr-only">Email</span>
                  <input
                    name="email"
                    type="email"
                    autocomplete="email"
                    required
                    placeholder="留下 email，下一期開放通知你"
                  />
                </label>
                <button class="button button--primary" type="submit"
                  >訂閱提醒</button
                >
                <a class="button button--quiet" href={archiveHref}
                  >先看歷年作品</a
                >
              </form>
              <p
                class="cta-reminder-form__status"
                id="cta-reminder-status"
                role="status"
                aria-live="polite"
              ></p>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <span>Matters 七日書 · 自由寫</span>
      <a href={partnersHref}>機構合作入口 →</a>
    </footer>

    <dialog
      class="reminder-dialog"
      id="reminder-dialog"
      aria-labelledby="reminder-title"
      data-contact-email={contactEmail}
      data-endpoint={EMAIL_REMINDER_ENDPOINT}
    >
      <div class="reminder-dialog__inner">
        <h2 id="reminder-title">獲得活動提醒郵件</h2>
        <p>留下 email，我們會在下一期七日書開放時通知你。</p>
        <form class="reminder-form" id="reminder-form" novalidate>
          <label>
            Email
            <input
              name="email"
              type="email"
              autocomplete="email"
              required
              placeholder="you@example.com"
            />
          </label>
          <p class="reminder-form__status" id="reminder-status" role="status" aria-live="polite"></p>
          <div class="reminder-form__actions">
            <button
              class="button button--quiet"
              type="button"
              data-close-reminder>取消</button
            >
            <button class="button button--primary" type="submit" id="reminder-submit"
              >送出提醒需求</button
            >
          </div>
        </form>
      </div>
    </dialog>
  </div>

  <script is:inline>
    // 活動週狀態偵測：給 final CTA section 用（v2 改版後 hero CTA 不再切換）
    // 規則：今天落在 currentIssue.period 範圍內（例如 "2026/5/4 - 2026/5/11"）
    const ctaSection = document.getElementById("next-up");
    const periodStr = ctaSection?.getAttribute("data-current-period") || "";
    const isWritingWeek = (() => {
      if (!periodStr) return false;
      const [startStr, endStr] = periodStr.split(/\s*-\s*/);
      if (!startStr || !endStr) return false;
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const parseDate = (s) => {
        const parts = s.trim().split(/[\/\-]/).map(Number);
        return new Date(parts[0], parts[1] - 1, parts[2]);
      };
      const start = parseDate(startStr);
      const end = parseDate(endStr);
      end.setHours(23, 59, 59, 999);
      return today >= start && today <= end;
    })();

    // Final CTA section 切換 + 算剩餘天數
    if (ctaSection) {
      const writingBlock = ctaSection.querySelector(".cta-band__state--writing");
      const reminderBlock = ctaSection.querySelector(".cta-band__state--reminder");
      if (isWritingWeek && writingBlock && reminderBlock) {
        writingBlock.hidden = false;
        reminderBlock.hidden = true;
        // 算剩餘天數
        const [, endStr] = periodStr.split(/\s*-\s*/);
        const parts = endStr.trim().split(/[\/\-]/).map(Number);
        const end = new Date(parts[0], parts[1] - 1, parts[2], 23, 59, 59, 999);
        const today = new Date();
        const daysLeft = Math.max(0, Math.ceil((end - today) / (1000 * 60 * 60 * 24)));
        const daysEl = writingBlock.querySelector("[data-days-left]");
        if (daysEl) daysEl.textContent = String(daysLeft);
      }
      // else: 維持預設（reminder 顯示、writing 隱藏）
    }

    // §Section 6 prompt list 「查看更多」展開
    const promptExpandBtn = document.querySelector("[data-prompt-expand]");
    if (promptExpandBtn) {
      promptExpandBtn.addEventListener("click", () => {
        document.querySelectorAll("[data-prompt-item][hidden]").forEach((el) => {
          el.removeAttribute("hidden");
        });
        promptExpandBtn.parentElement.remove();
      });
    }

    // CTA section inline reminder form (非活動週 email 訂閱)
    const ctaForm = document.getElementById("cta-reminder-form");
    const ctaStatusEl = document.getElementById("cta-reminder-status");
    if (ctaForm) {
      const ctaEndpoint = ctaForm.getAttribute("data-endpoint") || "";
      const setCtaStatus = (msg, kind) => {
        if (!ctaStatusEl) return;
        ctaStatusEl.textContent = msg || "";
        ctaStatusEl.dataset.kind = kind || "";
      };
      ctaForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        const fd = new FormData(ctaForm);
        const email = String(fd.get("email") || "").trim();
        if (!email || !/.+@.+\..+/.test(email)) {
          setCtaStatus("請輸入有效的 email", "error");
          return;
        }
        const submit = ctaForm.querySelector("button[type=submit]");
        submit && (submit.disabled = true);
        setCtaStatus("送出中…", "loading");
        try {
          await fetch(ctaEndpoint, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "text/plain;charset=utf-8" },
            body: JSON.stringify({
              email,
              source: "landing-cta-inline",
              userAgent: navigator.userAgent,
              referrer: document.referrer || "",
            }),
          });
          setCtaStatus("✓ 已收到！下一期開放時會寄通知給你。", "success");
          ctaForm.reset();
        } catch (err) {
          setCtaStatus("送出失敗，請稍後再試。", "error");
          submit && (submit.disabled = false);
        }
      });
    }

    const dialog = document.getElementById("reminder-dialog");
    const form = document.getElementById("reminder-form");
    const statusEl = document.getElementById("reminder-status");
    const submitBtn = document.getElementById("reminder-submit");
    const endpoint = dialog?.getAttribute("data-endpoint") || "";
    const contactEmail =
      dialog?.getAttribute("data-contact-email") || "freewrite@matters.town";
    const openButtons = document.querySelectorAll("[data-open-reminder]");
    const closeButtons = document.querySelectorAll("[data-close-reminder]");

    const setStatus = (msg, kind) => {
      if (!statusEl) return;
      statusEl.textContent = msg || "";
      statusEl.dataset.kind = kind || "";
    };

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setStatus("", "");
        if (form) form.reset();
        if (submitBtn) submitBtn.disabled = false;
        if (dialog && typeof dialog.showModal === "function")
          dialog.showModal();
      });
    });

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => dialog?.close());
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const email = String(formData.get("email") || "").trim();
      if (!email || !/.+@.+\..+/.test(email)) {
        setStatus("請輸入有效的 email", "error");
        return;
      }
      if (!endpoint) {
        // Fallback：endpoint 沒設好就回到 mailto
        const subject = encodeURIComponent("我想收到七日書活動提醒");
        const body = encodeURIComponent(`請將這個 email 加入七日書活動提醒名單：${email}`);
        window.location.href = `mailto:${contactEmail}?subject=${subject}&body=${body}`;
        dialog?.close();
        return;
      }
      submitBtn && (submitBtn.disabled = true);
      setStatus("送出中…", "loading");
      try {
        // text/plain 避開 CORS preflight (Apps Script Web App 不接 preflight)
        await fetch(endpoint, {
          method: "POST",
          mode: "no-cors", // Apps Script doPost 不回 CORS header；no-cors 不讀 response 也 OK
          headers: { "Content-Type": "text/plain;charset=utf-8" },
          body: JSON.stringify({
            email,
            source: "landing-reminder",
            userAgent: navigator.userAgent,
            referrer: document.referrer || "",
          }),
        });
        setStatus("✓ 已收到！下一期開放時會寄通知給你。", "success");
        setTimeout(() => dialog?.close(), 1800);
      } catch (err) {
        setStatus("送出失敗，請稍後再試或直接寄信給我們。", "error");
        submitBtn && (submitBtn.disabled = false);
      }
    });
  </script>

</BaseLayout>
