---
// 金句牆 Memo Wall — 跨屆典藏的便利貼牆（站外博物館的一級頁面）
// 資料來源：src/data/quote-wall.ts（由 scripts/fetch-quote-wall.mjs 定期重抓）
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  quoteWall,
  quoteWallCount,
  quoteWallCampaigns,
} from "../data/quote-wall";
import { withBase } from "../utils/paths";

const title = "金句牆｜七日書博物館";
const description =
  quoteWallCount > 0
    ? `${quoteWallCount} 則文友親手摘下的金句，跨屆典藏在這面牆上。`
    : "文友親手摘下的金句，跨屆典藏在這面牆上。";
const articleUrl = (hash: string) =>
  hash ? `https://matters.town/a/${hash}` : "#";
---

<BaseLayout title={title} description={description}>
  <main class="wall-page">
    <header class="wall-hero">
      <a class="wall-back" href={withBase("/museum")}>← 七日書博物館</a>
      <h1 class="wall-title">金句牆</h1>
      <p class="wall-sub">{description}</p>
    </header>

    <section class="wall-controls">
      <button id="shuffle" class="wall-shuffle" type="button">🔀 洗牌</button>
      <div class="wall-filters" id="filters">
        <button class="wall-filter is-on" data-campaign="" type="button">全部屆數</button>
        {
          quoteWallCampaigns.map((c) => (
            <button class="wall-filter" data-campaign={c} type="button">
              {c}
            </button>
          ))
        }
      </div>
    </section>

    {
      quoteWallCount > 0 ? (
        <ul class="wall" id="wall">
          {quoteWall.map((q, i) => (
            <li
              class="memo"
              data-variant={i % 5}
              data-campaign={q.campaignName}
            >
              <a class="memo-link" href={articleUrl(q.articleHash)} target="_blank" rel="noreferrer">
                <figure class="memo-figure">
                  <blockquote class="memo-quote">{q.content}</blockquote>
                  <figcaption class="memo-meta">
                    <span class="memo-author">— {q.author}</span>
                    {q.campaignName && <span class="memo-src">{q.campaignName}</span>}
                  </figcaption>
                </figure>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="wall-empty">金句牆即將開放，敬請期待 ✨</p>
      )
    }
  </main>
</BaseLayout>

<style>
  .wall-page {
    max-width: 72rem;
    padding: 2rem 1rem 4rem;
    margin: 0 auto;
  }
  .wall-hero {
    margin-bottom: 1.5rem;
    text-align: center;
  }
  .wall-back {
    font-size: 0.8rem;
    color: var(--color-text-muted, #9fb0c0);
  }
  .wall-title {
    margin: 0.5rem 0 0.25rem;
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: var(--color-accent, #eaf4f7);
  }
  .wall-sub {
    font-size: 0.9rem;
    color: var(--color-text-muted, #9fb0c0);
  }

  .wall-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1.25rem;
  }
  .wall-shuffle,
  .wall-filter {
    padding: 0.25rem 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-muted, #aebdd2);
    cursor: pointer;
    background: var(--color-bg-glass, #141c2b);
    border: 1px solid var(--color-border-glass, #2a3650);
    border-radius: 999px;
  }
  .wall-shuffle {
    font-weight: 700;
    color: var(--color-accent, #7fd4cb);
  }
  .wall-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-left: auto;
  }
  .wall-filter.is-on {
    font-weight: 700;
    color: #16202e;
    background: var(--color-accent, #eaf4f7);
    border-color: var(--color-accent, #eaf4f7);
  }

  /* masonry-ish via CSS columns */
  .wall {
    column-count: 4;
    column-gap: 0.75rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  @media (max-width: 900px) {
    .wall {
      column-count: 2;
    }
  }
  @media (max-width: 520px) {
    .wall {
      column-count: 1;
    }
  }

  .memo {
    display: inline-block;
    width: 100%;
    margin: 0 0 0.75rem;
    break-inside: avoid;
  }
  .memo-link {
    display: block;
    padding: 0.85rem;
    color: #4a3f22;
    text-decoration: none;
    background: #fff6c9;
    border-radius: 0.5rem;
    box-shadow: 0 3px 10px rgb(0 0 0 / 35%);
    transition: transform 0.12s ease;
  }
  .memo-link:hover {
    transform: translateY(-2px) rotate(-0.5deg);
  }
  .memo[data-variant="1"] .memo-link { background: #ffe9c9; }
  .memo[data-variant="2"] .memo-link { background: #e7f3d6; }
  .memo[data-variant="3"] .memo-link { background: #dcefff; }
  .memo[data-variant="4"] .memo-link { background: #ffe2ef; }

  .memo-figure {
    margin: 0;
  }
  .memo-quote {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .memo-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-top: 0.6rem;
  }
  .memo-author {
    font-size: 0.72rem;
    color: #7a6a3c;
  }
  .memo-src {
    font-size: 0.66rem;
    color: #2f7d76;
  }

  .wall-empty {
    padding: 4rem 0;
    color: var(--color-text-muted, #9fb0c0);
    text-align: center;
  }
</style>

<script>
  // 純前端：洗牌 + 屆數篩選，都在已嵌入的靜態資料上做，不需要執行期 API
  const wall = document.getElementById("wall");
  const shuffleBtn = document.getElementById("shuffle");
  const filters = document.getElementById("filters");

  function shuffle() {
    if (!wall) return;
    const items = Array.from(wall.children);
    for (let i = items.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [items[i], items[j]] = [items[j], items[i]];
    }
    items.forEach((el) => wall.appendChild(el));
  }

  function applyFilter(campaign: string) {
    if (!wall) return;
    Array.from(wall.children).forEach((el) => {
      const node = el as HTMLElement;
      const match = !campaign || node.dataset.campaign === campaign;
      node.style.display = match ? "" : "none";
    });
  }

  shuffleBtn?.addEventListener("click", shuffle);

  filters?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".wall-filter") as HTMLElement | null;
    if (!btn) return;
    filters.querySelectorAll(".wall-filter").forEach((b) => b.classList.remove("is-on"));
    btn.classList.add("is-on");
    applyFilter(btn.dataset.campaign || "");
  });

  // 進場先洗一次，讓每次造訪看到不同排列
  shuffle();
</script>
