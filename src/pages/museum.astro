---
import BaseLayout from "../layouts/BaseLayout.astro";
import MattersWordmark from "../components/MattersWordmark.astro";
import SevenDayBookLogo from "../components/SevenDayBookLogo.astro";
import {
  allThemes,
  contactEmail,
  currentIssue,
  lectures,
  shared,
} from "../data/seven-day-campaign";
import {
  marathoners,
  totalGrandSlams,
  totalAuthorsWithArticles,
  eventCount,
} from "../data/freewrite-marathoners";
import GrandBadge from "../components/GrandBadge.astro";
import {
  featuredArticles,
  featuredCampaigns,
  featuredCount,
} from "../data/freewrite-featured";

// 預設只 show 12，使用者按 「展開更多」 +12
const FEATURED_INITIAL = 12;
// 馬拉松選手預設 show 3 行 (5 col × 3 row = 15)
const MARATHONERS_INITIAL = 15;
import "../styles/seven-day-campaign.css";
import { withBase } from "../utils/paths";

const homeHref = withBase("");
const partnersHref = withBase(shared.partnersHref);
const assetSrc = (src?: string) => {
  if (!src) return "";
  return src.startsWith("http") ? src : withBase(src);
};

// 24 期主題倒序：最新在前
const archiveThemes = [...allThemes].reverse();

const promptStateLabel: Record<string, string> = {
  past: "已開放",
  today: "今日題目",
  locked: "即將開放",
};
// 名家講座預設 show 6 位、按「展開更多」秀全部
const LECTURES_INITIAL = 6;

// 本月七題：把 prompt.date ("5/4") 補上年份，轉成 ISO「2026-05-04」
// 之後 client-side 會用這個 ISO 算「今天距該日 N 天」即時更新狀態
const issueYear = Number(currentIssue.period.split("/")[0]) || new Date().getFullYear();
const promptIso = (mdStr: string) => {
  const [m, d] = mdStr.split("/").map(Number);
  return `${issueYear}-${String(m).padStart(2, "0")}-${String(d).padStart(2, "0")}`;
};
---

<BaseLayout
  title="七日書博物館"
  description="七日書博物館：從 2024 春到現在，24 期主題的圖片彙整 — 把每一期書寫的痕跡留下來。"
>
  <div class="campaign-page campaign-page--dark" data-page="archive">
    <header class="sitebar sitebar--dark">
      <a
        class="sitebar__brand"
        href="https://matters.town"
        target="_blank"
        rel="noopener"
        aria-label="Matters · 七日書 · 博物館"
      >
        <MattersWordmark size={18} />
        <span class="sitebar__dot" aria-hidden="true">·</span>
        <SevenDayBookLogo size={20} title="七日書" className="seven-day-book-logo--on-dark" />
        <span class="sitebar__brand-suffix">博物館</span>
      </a>

      <nav class="sitebar__nav" aria-label="頁面導覽">
        <a href="#marathoners">名人堂</a>
        <a href="#my-journey">我的旅程</a>
        <a href="#current-issue">本月七題</a>
        <a href="#featured">歷年精選</a>
        <a href="#lectures">名家講座</a>
        <a href={homeHref}>七日書介紹</a>
        <a href={partnersHref}>合作洽談</a>
      </nav>

      <div class="sitebar__actions">
        <a
          class="button button--soft"
          href={shared.joinHref}
          target="_blank"
          rel="noopener">加入本月寫作</a
        >
      </div>
    </header>

    <main>
      <section class="archive-hero archive-hero--centered" aria-labelledby="archive-title">
        <div class="archive-hero__inner">
          <h1 id="archive-title" class="archive-hero__title">七日書博物館</h1>
          <p class="archive-hero__lead">
            七日書從 2024 春開始，每個月進行一次為期七天的活動。
            至今已經進行 {archiveThemes.length} 期、3,200+ 位文友、9,000+ 篇人生。
            七日書博物館收集了所有文友的點點滴滴。
          </p>
        </div>
      </section>

      <!-- 博物館入口 banner：cover 圖鋪在最外層（全寬背景），內框維持 dark box -->
      <section class="museum-banner" aria-hidden="true">
        <div
          class="museum-banner__bg"
          style={`background-image: url('https://imagedelivery.net/kDRCweMmqLnTPNlbum-pYA/prod/campaignCover/fb1bd2c2-754d-493b-9750-352ef7fe27b7.png/w=1920,h=600,fit=cover');`}
          aria-hidden="true"
        ></div>
        <div class="museum-banner__overlay" aria-hidden="true"></div>
        <div class="museum-banner__inner">
          <img class="museum-banner__scribble museum-banner__scribble--tr" src={withBase("images/freewrite/scribble-tr.svg")} alt="" />
          <div class="museum-banner__content">
            <SevenDayBookLogo size={72} title="七日書" className="seven-day-book-logo--on-dark museum-banner__logo" />
            <p class="museum-banner__tagline">自由寫療癒了我們想寫字的心，七日書是一座持續長大的博物館</p>
          </div>
          <img class="museum-banner__scribble museum-banner__scribble--bl" src={withBase("images/freewrite/scribble-bl.svg")} alt="" />
        </div>
      </section>

      <section
        id="marathoners"
        class="museum-marathoners"
        aria-labelledby="marathoners-title"
      >
        <div class="museum-marathoners__inner">
          <header class="museum-marathoners__head">
            <p class="eyebrow">七日書馬拉松選手</p>
            <h2 id="marathoners-title">這裡是七日書的名人堂。</h2>
            <p>
              他們幾乎參與了所有七日書，是最擅長長跑的文友。點頭像可以看那位文友的書寫旅程。
            </p>
            <p>
              完成七天寫作，就可以擁有大滿貫徽章；這兩年以來，我們總共發出了
              <strong>{totalGrandSlams.toLocaleString()}</strong> 枚大滿貫徽章。
            </p>
          </header>

          <ol
            class="marathoner-grid"
            data-marathoner-grid
            data-initial={MARATHONERS_INITIAL}
          >
            {
              marathoners.map((m, idx) => {
                const rankClass =
                  idx < 3 ? "marathoner-card--gold" : idx < 10 ? "marathoner-card--silver" : "";
                return (
                  <li
                    data-marathoner-item={idx}
                    hidden={idx >= MARATHONERS_INITIAL}
                  >
                    <button
                      type="button"
                      class={`marathoner-card ${rankClass}`}
                      data-marathoner-handle={m.userName}
                      aria-label={`查看 ${m.displayName} 的書寫旅程`}
                    >
                      <span class="marathoner-card__rank">
                        {String(idx + 1).padStart(2, "0")}
                      </span>
                      {m.grandSlams > 0 && (
                        <span
                          class="marathoner-card__badge"
                          title={`拿到 ${m.grandSlams} 次大滿貫徽章`}
                        >
                          <GrandBadge size={26} />
                          <span class="marathoner-card__badge-num">×{m.grandSlams}</span>
                        </span>
                      )}
                      {m.avatar ? (
                        <img
                          class="marathoner-card__avatar"
                          src={m.avatar}
                          alt=""
                          loading="lazy"
                          referrerpolicy="no-referrer"
                        />
                      ) : (
                        <span class="marathoner-card__avatar marathoner-card__avatar--empty" aria-hidden="true">
                          {m.displayName.slice(0, 1)}
                        </span>
                      )}
                      <span class="marathoner-card__name">{m.displayName}</span>
                      <span class="marathoner-card__handle">@{m.userName}</span>
                      <span class="marathoner-card__count">
                        {m.totalArticles} <span>篇</span>
                      </span>
                      <span class="marathoner-card__sub">
                        {m.campaignsParticipated} 期參與
                      </span>
                    </button>
                  </li>
                );
              })
            }
          </ol>

          <div class="theme-pager__more">
            <button
              class="button button--soft"
              type="button"
              data-marathoner-expand
              aria-expanded="false"
            >
              <span data-marathoner-expand-label
                >查看更多長跑選手 ↓</span
              >
            </button>
          </div>
        </div>
      </section>

      <section
        id="my-journey"
        class="museum-passport"
        aria-labelledby="my-journey-title"
      >
        <div class="museum-passport__inner">
          <header class="museum-passport__head">
            <p class="eyebrow">我的書寫旅程</p>
            <h2 id="my-journey-title">在博物館裡，找你自己的展廳。</h2>
            <p>
              輸入你在 Matters 的帳號，看看你曾在哪幾期七日書留下文字 —
              然後一鍵把這些足跡做成一本可愛的小書，自己留著、送朋友都可以。
            </p>
          </header>

          <form class="passport-search passport-search--on-dark" id="museum-passport-search" novalidate>
            <label class="passport-search__field">
              <span class="passport-search__prefix" aria-hidden="true">@</span>
              <input
                type="text"
                name="handle"
                id="museum-passport-handle"
                placeholder="你的 Matters 帳號"
                autocomplete="off"
                spellcheck="false"
                inputmode="text"
                required
              />
            </label>
            <button class="button button--soft" type="submit">
              查找我的旅程 →
            </button>
          </form>

          <div
            class="passport-result passport-result--on-dark"
            id="museum-passport-result"
            role="status"
            aria-live="polite"
          >
            <p class="passport-hint">
              提示：你的帳號就是 Matters 個人頁網址 <code>matters.town/@___</code> 後面那段。
            </p>
          </div>
        </div>
      </section>

      <section
        id="current-issue"
        class="museum-current"
        aria-labelledby="current-issue-title"
      >
        <div class="museum-current__inner">
          <header class="museum-current__head">
            <p class="eyebrow">本月正在發生</p>
            <h2 id="current-issue-title">
              {currentIssue.title}：本月七天，現場直播。
            </h2>
            <p>
              {currentIssue.period} · {currentIssue.summary}
            </p>
            <p class="museum-current__cta">
              <a href={currentIssue.eventHref} target="_blank" rel="noopener"
                >到 Matters 看活動頁 →</a
              >
              <a href={currentIssue.announcementHref} target="_blank" rel="noopener"
                >讀本期主題公告 →</a
              >
            </p>
          </header>

          <p class="museum-current__progress" data-issue-progress aria-live="polite">
            <span data-issue-progress-text>本期共 {currentIssue.prompts.length} 道題目</span>
          </p>

          <ol class="day-unlock-strip day-unlock-strip--full day-unlock-strip--on-dark" aria-label="本期七道題目">
            {
              currentIssue.prompts.map((prompt) => (
                <li
                  class={`day-unlock-card day-unlock-card--${prompt.state}`}
                  data-day-card
                  data-day-iso={promptIso(prompt.date)}
                >
                  <div class="day-unlock-card__top">
                    <span>{prompt.date}</span>
                    <span data-day-status>
                      {promptStateLabel[prompt.state] ?? "題目"}
                    </span>
                  </div>
                  <span class="day-unlock-card__day">{prompt.day}</span>
                  <h3>{prompt.title}</h3>
                  <p>{prompt.prompt}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <section class="archive-grid-section" aria-label="歷來七日書主題">
        <div class="archive-grid">
          {
            archiveThemes.map((theme) => (
              <a
                class="archive-card"
                href={theme.announceHref}
                target="_blank"
                rel="noopener"
              >
                <div class="archive-card__media">
                  <img
                    src={assetSrc(theme.announceCover)}
                    alt={`${theme.name} 主視覺`}
                    loading="lazy"
                  />
                </div>
                <div class="archive-card__caption">
                  <div class="archive-card__caption-top">
                    <span class="archive-card__month">{theme.monthLabel}</span>
                    {theme.phase && (
                      <span class={`archive-card__phase archive-card__phase--${theme.phase === "進行中" ? "live" : "done"}`}>
                        {theme.phase}
                      </span>
                    )}
                  </div>
                  <h2>{theme.name}</h2>
                  {theme.participants && (
                    <p class="archive-card__meta">
                      {theme.participants} 位文友參與
                      {theme.newcomers && ` · 其中 ${theme.newcomers} 位新作者`}
                    </p>
                  )}
                </div>
              </a>
            ))
          }
        </div>
      </section>

      <section
        id="featured"
        class="museum-featured"
        aria-labelledby="featured-title"
      >
        <div class="museum-featured__inner">
          <header class="museum-featured__head">
            <p class="eyebrow">歷年精選文章</p>
            <h2 id="featured-title">
              {featuredCount} 篇被七日書官方留言「精選」過的文章。
            </h2>
            <p>
              這些是七日書策展團隊一篇一篇挑出來、放進每期展廳裡的常設典藏。
              {featuredCampaigns.length} 期 ·  {featuredCount} 篇。
              沿著時間軸找一場有興趣的展覽，或從最近一期開始翻。
            </p>
          </header>

          {(() => {
            // 把 19 期分到 2024 / 2025 / 2026 三組，依時間排序
            const years = [...new Set(featuredCampaigns.map((c) => c.year))].sort();
            const grouped = years.map((y) => ({
              year: y,
              campaigns: featuredCampaigns
                .filter((c) => c.year === y)
                .sort((a, b) => a.month - b.month),
            }));
            return (
              <nav
                class="featured-timeline"
                data-featured-chips
                aria-label="按時間軸切換期數"
              >
                {
                  grouped.map((g) => (
                    <div class="featured-tl-year">
                      <span class="featured-tl-year__label">{g.year}</span>
                      <ol class="featured-tl-year__chips">
                        {g.campaigns.map((c) => (
                          <li>
                            <button
                              type="button"
                              class="featured-tl-chip"
                              data-chip-target={c.shortHash}
                              title={c.name}
                            >
                              <span class="featured-tl-chip__month">
                                {String(c.month).padStart(2, "0")} 月
                              </span>
                              <span class="featured-tl-chip__label">{c.label}</span>
                              <span class="featured-tl-chip__count">{c.count} 篇</span>
                            </button>
                          </li>
                        ))}
                      </ol>
                    </div>
                  ))
                }
              </nav>
            );
          })()}

          <div
            class="featured-grid"
            data-featured-grid
            data-initial={FEATURED_INITIAL}
          >
            {
              featuredArticles.map((a, idx) => {
                const trimmed =
                  (a.summary || "").length > 84
                    ? (a.summary || "").slice(0, 84) + "…"
                    : a.summary;
                const month = a.createdAt
                  ? `${a.createdAt.slice(0, 4)} / ${Number(a.createdAt.slice(5, 7))}`
                  : "";
                return (
                  <a
                    class="featured-card"
                    data-featured-card
                    data-campaign={a.campaignHash}
                    data-index={idx}
                    href={`https://matters.town/a/${a.shortHash}`}
                    target="_blank"
                    rel="noopener"
                    hidden={idx >= FEATURED_INITIAL}
                  >
                    {a.cover ? (
                      <div class="featured-card__media">
                        <img src={a.cover} alt="" loading="lazy" referrerpolicy="no-referrer" />
                      </div>
                    ) : (
                      <div class="featured-card__media featured-card__media--empty" aria-hidden="true">
                        <span>{a.title.slice(0, 1)}</span>
                      </div>
                    )}
                    <div class="featured-card__body">
                      <p class="featured-card__meta">
                        <span>{month}</span>
                        <span class="featured-card__campaign">{a.campaignName.replace("七日書｜", "").replace("七日書：", "").replace("三日書｜", "三日書·").replace("三日書：", "三日書·")}</span>
                      </p>
                      <h3 class="featured-card__title">{a.title}</h3>
                      <p class="featured-card__summary">{trimmed}</p>
                      <div class="featured-card__author">
                        {a.author.avatar ? (
                          <img src={a.author.avatar} alt="" loading="lazy" referrerpolicy="no-referrer" />
                        ) : (
                          <span class="featured-card__author-fallback" aria-hidden="true">{a.author.displayName.slice(0, 1)}</span>
                        )}
                        <span>{a.author.displayName}</span>
                      </div>
                    </div>
                  </a>
                );
              })
            }
          </div>

          <div class="theme-pager__more">
            <button
              class="button button--soft"
              type="button"
              data-featured-more
              aria-expanded="false"
            >
              <span data-featured-more-label>展開更多 12 篇 ↓</span>
            </button>
          </div>
        </div>
      </section>

      <section
        id="lectures"
        class="museum-lectures"
        aria-labelledby="lectures-title"
      >
        <div class="museum-lectures__inner">
          <header class="museum-lectures__head">
            <p class="eyebrow">名家講座</p>
            <h2 id="lectures-title">每月一位作家、詩人、研究者，陪文友書寫。</h2>
            <p>
              從 2024 年至今已邀請 {lectures.length} 位老師，其中{" "}
              {lectures.filter((l) => l.hasTranscript).length} 場有完整文字精華，
              留下來的講座變成可以反覆回看的寫作課。
            </p>
          </header>

          <div
            class="lecture-grid lecture-grid--dense lecture-grid--on-dark"
            data-lecture-grid
            data-initial={LECTURES_INITIAL}
          >
            {
              lectures.map((lecture, idx) => (
                <article
                  class="lecture-card lecture-card--compact lecture-card--on-dark"
                  data-lecture-item={idx}
                  hidden={idx >= LECTURES_INITIAL}
                >
                  <div class="lecture-card__speaker lecture-card__speaker--text">
                    <strong>{lecture.speaker}</strong>
                    <span>
                      {lecture.role} · {lecture.theme}
                    </span>
                  </div>
                  {lecture.hasTranscript ? (
                    <>
                      <p class="lecture-card__excerpt">
                        {lecture.summary &&
                          (lecture.summary.length > 80
                            ? lecture.summary.slice(0, 80) + "…"
                            : lecture.summary)}
                      </p>
                      <a
                        class="lecture-card__link"
                        href={lecture.href}
                        target="_blank"
                        rel="noopener"
                      >
                        閱讀文字精華 →
                      </a>
                    </>
                  ) : (
                    <>
                      <p class="lecture-card__excerpt">{lecture.note}</p>
                      <span class="lecture-card__pill">講座記錄整理中</span>
                    </>
                  )}
                </article>
              ))
            }
          </div>

          <div class="theme-pager__more">
            <button
              class="button button--soft"
              type="button"
              data-lecture-expand
              aria-expanded="false"
            >
              <span data-lecture-expand-label
                >展開更多 {lectures.length - LECTURES_INITIAL} 位講者 ↓</span
              >
            </button>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="archive-cta-title">
        <div class="section__inner">
          <div class="cta-band cta-band--ghost">
            <h2 id="archive-cta-title">下一個七天，一起寫。</h2>
            <p>
              在每個月的開始，會打開新的七道題目。如果你也想加入，現在就可以從本期或任何一期開始。
            </p>
            <div class="cta-band__actions">
              <a
                class="button button--soft"
                href={shared.joinHref}
                target="_blank"
                rel="noopener">加入本期寫作</a
              >
              <a class="button button--ghost-on-dark" href={homeHref}
                >回到首頁看本月主題</a
              >
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer page-footer--dark">
      <span>Matters 七日書 · 自由寫</span>
      <span>
        合作洽談：<a href={`mailto:${contactEmail}`}>{contactEmail}</a>
      </span>
    </footer>

    <!-- 一鍵製作專屬七日書小書 overlay — 印 PDF 用 window.print() + @page A5 portrait
         注意：用 <div role="dialog">（不是 <dialog>），因為 <dialog> 走 browser top-layer，
         Chrome / Safari 列印時會把整個 top-layer 當一頁渲染導致空白頁。 -->
    <div
      class="book-modal"
      id="book-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="book-modal-title"
      hidden
    >
      <div class="book-modal__backdrop" data-close-book></div>
      <div class="book-modal__panel">
        <div class="book-modal__chrome">
          <div class="book-modal__chrome-left">
            <h2 id="book-modal-title">你的七日書小書</h2>
            <p>翻翻看下方預覽 — 想印實體就按「下載 PDF」（A5 開本），<br/>想在手機上讀就按「下載 EPUB」（自由縮放、Apple Books / Kobo 都能開）。</p>
          </div>
          <div class="book-modal__chrome-actions">
            <button
              class="button button--quiet"
              type="button"
              data-close-book>關閉</button
            >
            <button
              class="button button--soft"
              type="button"
              data-epub-book>下載 EPUB ↓</button
            >
            <button
              class="button button--primary"
              type="button"
              data-print-book>下載 PDF →</button
            >
          </div>
        </div>
        <div class="book-modal__pages" id="book-modal-pages">
          <p class="book-modal__placeholder">
            先在上方輸入帳號查找旅程，再回來這裡。
          </p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // ── /museum 個人足跡：跟 / 寫作者頁同 logic 但加「製作我的小書」按鈕 ──
    const passportForm = document.getElementById("museum-passport-search");
    const passportResult = document.getElementById("museum-passport-result");
    const passportInput = document.getElementById("museum-passport-handle");
    const bookModal = document.getElementById("book-modal");
    const bookPagesEl = document.getElementById("book-modal-pages");
    const printBtn = document.querySelector("[data-print-book]");
    const epubBtn = document.querySelector("[data-epub-book]");
    const closeBtn = document.querySelector("[data-close-book]");

    const MATTERS_GQL = "https://server.matters.town/graphql";
    const MATTERS_BASE = "https://matters.town";
    const FREEWRITE_NEEDLE = ["七日書", "三日書", "自由寫", "情書", "兩廳院"];

    // 全域暫存最後一次查詢結果，按下「製作小書」時用
    let lastJourney = null;

    const escapeHtml = (s) =>
      String(s ?? "").replace(/[&<>"']/g, (c) => (
        { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]
      ));

    const fetchUserArticles = async (handle) => {
      // 加 cover + summary + contents.markdown，小書直接取用內文與圖片
      const query = `query($userName: String!) {
        user(input: { userName: $userName }) {
          userName displayName avatar
          articles(input: { first: 100 }) {
            edges {
              node {
                shortHash slug title createdAt cover summary
                contents { markdown }
                campaigns { campaign { shortHash name } }
              }
            }
          }
        }
      }`;
      const res = await fetch(MATTERS_GQL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ query, variables: { userName: handle } }),
      });
      const json = await res.json();
      if (json.errors) throw new Error(json.errors[0]?.message || "GraphQL error");
      return json.data.user;
    };

    // Matters 的 contents.markdown 其實是「markdown + raw HTML」混合：
    //   - 圖片走 <figure class="image"><img src="..."><figcaption>...</figcaption></figure>
    //   - 空段落走 <p><br class="smart"></p>
    //   - <br class="smart"> 也會直接出現在段落中
    // 所以這裡先抽出所有 <figure class="image">、再把剩下的 HTML / markdown 標籤剝乾淨，
    // 切段落後重新組裝成乾淨的 book HTML。
    const extractFigures = (raw) => {
      // 把 <figure class="image"...><img src="X" ...><figcaption>...</figcaption></figure>
      // 換成 placeholder N + 收集進 figures[]
      const figures = [];
      const out = raw.replace(
        /<figure[^>]*class="[^"]*\bimage\b[^"]*"[^>]*>([\s\S]*?)<\/figure>/gi,
        (_m, inner) => {
          const imgMatch = inner.match(/<img[^>]*\bsrc=["']([^"']+)["'][^>]*>/i);
          if (!imgMatch) return ""; // 沒 src 就丟掉
          const altMatch = inner.match(/<img[^>]*\balt=["']([^"']*)["']/i);
          const capMatch = inner.match(/<figcaption[^>]*>([\s\S]*?)<\/figcaption>/i);
          const idx = figures.length;
          figures.push({
            src: imgMatch[1],
            alt: altMatch ? altMatch[1] : "",
            caption: capMatch ? capMatch[1].replace(/<[^>]+>/g, "").trim() : "",
          });
          return `FIG${idx}`;
        },
      );
      return { text: out, figures };
    };

    const stripInlineHtml = (s) =>
      String(s)
        // 拔掉 XML 不允許的 ASCII control chars (U+0001-08, 0B-0C, 0E-1F)。
        // Matters editor 偶爾會留 U+0001 在 figure 後的空行，會讓 EPUB
        // 的 XHTML parser 整個 fail。
        .replace(/[\x00-\x08\x0B\x0C\x0E-\x1F]/g, "")
        // <br class="smart"> / <br/> / <br> → 統一 \n
        .replace(/<br\s*[^>]*>/gi, "\n")
        // 其他 inline tag 一律拔掉，保留純文字
        .replace(/<\/?(?:span|em|strong|b|i|u|a|code|small|sub|sup|mark|ins|del|s)[^>]*>/gi, "")
        // 殘留所有未識別 tag 也拔掉（不要把 raw <div> 字串塞給使用者）
        .replace(/<\/?[a-z][^>]*>/gi, "");

    // 完整 markdown / HTML 混合 → 乾淨 HTML：段落 / 標題 / 圖片 / 引言
    const mdToHtml = (md) => {
      if (!md) return "";
      const { text, figures } = extractFigures(md);
      // 段落切分：以兩個換行為界，但保留圖片 placeholder 為獨立段落
      const blocks = text
        .replace(/FIG(\d+)/g, "\n\nFIG$1\n\n")
        .split(/\n\s*\n+/);
      const html = blocks
        .map((blk) => {
          const t = blk.trim();
          if (!t) return "";
          // 圖片 placeholder
          const figMatch = t.match(/^FIG(\d+)$/);
          if (figMatch) {
            const f = figures[Number(figMatch[1])];
            if (!f) return "";
            const cap = f.caption
              ? `<figcaption>${escapeHtml(f.caption)}</figcaption>`
              : "";
            return `<figure class="book-article-fig"><img src="${escapeHtml(f.src)}" alt="${escapeHtml(f.alt)}" loading="lazy" />${cap}</figure>`;
          }
          // Heading（# / ## / ### → 統一渲染 h3 級）
          const h = t.match(/^(#{1,6})\s+(.+)$/);
          if (h) {
            const txt = escapeHtml(stripInlineHtml(h[2]).replace(/[*_`]/g, "").trim());
            if (!txt) return "";
            return `<h3>${txt}</h3>`;
          }
          // Image-only markdown block
          const img = t.match(/^!\[([^\]]*)\]\(([^)]+)\)$/);
          if (img) {
            return `<figure class="book-article-fig"><img src="${escapeHtml(img[2])}" alt="${escapeHtml(img[1])}" loading="lazy" /></figure>`;
          }
          // Block quote
          if (t.startsWith("> ")) {
            const q = escapeHtml(
              stripInlineHtml(t.slice(2))
                .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
                .replace(/[*_`]/g, "")
                .trim(),
            );
            if (!q) return "";
            return `<blockquote>${q}</blockquote>`;
          }
          // Paragraph：先剝 HTML、再去 markdown
          const cleaned = stripInlineHtml(t)
            .replace(/!\[[^\]]*\]\([^)]+\)/g, "")
            .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
            .replace(/\*\*([^*]+)\*\*/g, "$1")
            .replace(/\*([^*]+)\*/g, "$1")
            .replace(/`([^`]+)`/g, "$1")
            .trim();
          if (!cleaned) return "";
          // 段落內手動換行 → <br/>
          const escaped = escapeHtml(cleaned).replace(/\n+/g, "<br/>");
          return `<p>${escaped}</p>`;
        })
        .filter(Boolean)
        .join("");
      return html;
    };

    const groupByCampaign = (articles) => {
      const groups = new Map();
      articles.forEach((a) => {
        const c = (a.campaigns || []).find((c) =>
          FREEWRITE_NEEDLE.some((n) => (c.campaign?.name || "").includes(n)),
        )?.campaign;
        if (!c) return;
        if (!groups.has(c.shortHash))
          groups.set(c.shortHash, { campaign: c, articles: [] });
        groups.get(c.shortHash).articles.push(a);
      });
      return [...groups.values()].sort((a, b) => {
        const da = Math.max(...a.articles.map((x) => +new Date(x.createdAt)));
        const db = Math.max(...b.articles.map((x) => +new Date(x.createdAt)));
        return db - da;
      });
    };

    const formatMonthLabel = (iso) => {
      if (!iso) return "";
      const [y, m] = iso.split("T")[0].split("-");
      return `${y} 年 ${Number(m)} 月`;
    };

    const renderResult = (user) => {
      if (!user) {
        passportResult.innerHTML = `
          <div class="passport-empty">
            <h3>找不到這位文友的 Matters 帳號</h3>
            <p>請確認帳號拼寫是否正確。</p>
          </div>`;
        lastJourney = null;
        return;
      }
      const articles = (user.articles?.edges || [])
        .map((e) => e.node)
        .filter((a) =>
          (a.campaigns || []).some((c) =>
            FREEWRITE_NEEDLE.some((n) => (c.campaign?.name || "").includes(n)),
          ),
        );

      if (!articles.length) {
        passportResult.innerHTML = `
          <div class="passport-empty">
            <h3>${escapeHtml(user.displayName)} 還沒在七日書留下足跡</h3>
            <p>查到 <a href="${MATTERS_BASE}/@${escapeHtml(user.userName)}" target="_blank" rel="noopener">@${escapeHtml(user.userName)}</a> 的 Matters 公開頁面，但沒看到七日書相關文章。</p>
          </div>`;
        lastJourney = null;
        return;
      }

      const groups = groupByCampaign(articles);
      lastJourney = { user, groups, totalArticles: articles.length };

      const profileUrl = `${MATTERS_BASE}/@${user.userName}`;
      const groupHtml = groups
        .map((g) => {
          const period = g.articles.map((a) => formatMonthLabel(a.createdAt)).filter(Boolean)[0];
          const eventUrl = `${MATTERS_BASE}/e/${g.campaign.shortHash}`;
          const articleList = g.articles
            .sort((a, b) => +new Date(a.createdAt) - +new Date(b.createdAt))
            .map(
              (a) => `
              <li>
                <a href="${MATTERS_BASE}/a/${escapeHtml(a.shortHash)}" target="_blank" rel="noopener">
                  ${escapeHtml(a.title)}
                </a>
                <span class="passport-article__date">${escapeHtml(a.createdAt.slice(0, 10))}</span>
              </li>`,
            ).join("");
          return `
            <article class="passport-group">
              <header class="passport-group__head">
                <div>
                  <p class="passport-group__meta">${escapeHtml(period || "")} · ${g.articles.length} 篇</p>
                  <h3>${escapeHtml(g.campaign.name)}</h3>
                </div>
                <a class="passport-group__link" href="${eventUrl}" target="_blank" rel="noopener">看活動頁 →</a>
              </header>
              <ul class="passport-group__articles">${articleList}</ul>
            </article>`;
        }).join("");

      passportResult.innerHTML = `
        <div class="passport-found">
          <header class="passport-found__head">
            ${user.avatar ? `<img class="passport-found__avatar" src="${escapeHtml(user.avatar)}" alt="" />` : ""}
            <div>
              <p class="passport-found__name">
                ${escapeHtml(user.displayName)}
                <a href="${profileUrl}" target="_blank" rel="noopener">@${escapeHtml(user.userName)} →</a>
              </p>
              <p class="passport-found__stats">
                在 <strong>${groups.length}</strong> 期七日書活動裡，留下 <strong>${articles.length}</strong> 篇文章
              </p>
            </div>
            <button
              class="button button--soft passport-found__book-btn"
              type="button"
              data-open-book>製作我的七日書小書 →</button
            >
          </header>
          <div class="passport-groups">${groupHtml}</div>
        </div>`;

      // re-bind open-book button (innerHTML refreshed)
      const openBtn = passportResult.querySelector("[data-open-book]");
      openBtn?.addEventListener("click", openBook);
    };

    // ── 小書 builder ──────────────────────────────────────────
    // 結構：cover → stats → TOC → for each issue: divider + per-article pages → closing
    // 封面/封底/divider/closing 都用 design-system POAP scribble + 七日書 SVG logo
    const SDB_LOGO_SRC = "/images/freewrite/seven-day-book-logo.svg";
    const SCRIBBLE_TR = "/images/freewrite/scribble-tr.svg";
    const SCRIBBLE_BL = "/images/freewrite/scribble-bl.svg";
    // 七日書宣傳圖（freewrite studio 系列），用在 divider 頁背景與 closing 頁
    // 1536×1024 攝影風格，按 issue index cycle，避免每張 divider 都長一樣
    const STUDIO_ART = [
      "/images/seven-day/optimized/studio-life-ledger.jpg",
      "/images/seven-day/optimized/studio-closet-self.jpg",
      "/images/seven-day/optimized/studio-smell-museum.jpg",
      "/images/seven-day/optimized/studio-workplace-persona.jpg",
    ];

    const buildBookHtml = (journey) => {
      if (!journey) return "";
      const { user, groups, totalArticles } = journey;
      const today = new Date();
      const dateStr = `${today.getFullYear()} 年 ${today.getMonth() + 1} 月 ${today.getDate()} 日`;

      // ── Cover page：七日書 SVG 大尺寸 + 兩個 POAP scribble + freewrite gradient ──
      const cover = `
        <article class="book-page book-page--cover">
          <img class="book-scribble book-scribble--tr" src="${SCRIBBLE_TR}" alt="" />
          <img class="book-scribble book-scribble--bl" src="${SCRIBBLE_BL}" alt="" />
          <div class="book-cover-content">
            <p class="book-cover-eyebrow">Matters · 自由寫</p>
            <img class="book-cover-logo" src="${SDB_LOGO_SRC}" alt="七日書" />
            <h1 class="book-cover-title">${escapeHtml(user.displayName)}<br/>的小書</h1>
            <p class="book-cover-handle">@${escapeHtml(user.userName)}</p>
          </div>
          <p class="book-cover-date">${dateStr} 編製</p>
        </article>`;

      // ── Stats page ─────────────────────────────────────────
      const firstYear = groups.length
        ? formatMonthLabel(groups[groups.length - 1].articles[0].createdAt).split(' 年')[0]
        : '—';
      const stats = `
        <article class="book-page book-page--stats">
          <img class="book-scribble book-scribble--tr" src="${SCRIBBLE_TR}" alt="" />
          <p class="book-stats-eyebrow">這幾年的書寫</p>
          <div class="book-stats-grid">
            <div><strong>${groups.length}</strong><span>期七日書</span></div>
            <div><strong>${totalArticles}</strong><span>篇文章</span></div>
            <div><strong>${firstYear}</strong><span>第一次參與</span></div>
          </div>
          <p class="book-stats-tagline">每一篇都是一個七天裡安靜的下午。</p>
          <img class="book-scribble book-scribble--bl" src="${SCRIBBLE_BL}" alt="" />
        </article>`;

      // ── TOC page ──────────────────────────────────────────
      const tocItems = groups
        .map((g, i) => {
          const earliestArt = [...g.articles].sort((a, b) => +new Date(a.createdAt) - +new Date(b.createdAt))[0];
          const period = formatMonthLabel(earliestArt.createdAt);
          return `<li><span class="book-toc-no">${String(i + 1).padStart(2, "0")}</span><span class="book-toc-title">${escapeHtml(g.campaign.name)}</span><span class="book-toc-date">${escapeHtml(period)}</span></li>`;
        }).join("");
      const toc = `
        <article class="book-page book-page--toc">
          <img class="book-scribble book-scribble--tr" src="${SCRIBBLE_TR}" alt="" />
          <p class="book-page-eyebrow">目錄</p>
          <h2 class="book-page-h2">這本書收錄的 ${groups.length} 期</h2>
          <ol class="book-toc-list">${tocItems}</ol>
          <img class="book-cover-logo book-toc-logo" src="${SDB_LOGO_SRC}" alt="七日書" />
        </article>`;

      // ── Per-issue: divider page + per-article pages ────────
      const issuePages = groups
        .map((g, i) => {
          const period = formatMonthLabel(g.articles[0].createdAt);
          const sortedArts = [...g.articles].sort(
            (a, b) => +new Date(a.createdAt) - +new Date(b.createdAt),
          );

          // Divider page (一張，主題大字 + 月份 + freewrite studio 宣傳圖背景)
          const studioArt = STUDIO_ART[i % STUDIO_ART.length];
          const divider = `
            <article class="book-page book-page--divider">
              <div class="book-divider-art" style="background-image: url('${studioArt}')" aria-hidden="true"></div>
              <div class="book-divider-mask" aria-hidden="true"></div>
              <img class="book-scribble book-scribble--tr" src="${SCRIBBLE_TR}" alt="" />
              <div class="book-divider-content">
                <p class="book-divider-section">第 ${String(i + 1).padStart(2, "0")} 站</p>
                <p class="book-divider-period">${escapeHtml(period)}</p>
                <h2 class="book-divider-title">${escapeHtml(g.campaign.name)}</h2>
                <p class="book-divider-meta">在這期，你寫了 ${sortedArts.length} 篇</p>
              </div>
              <img class="book-scribble book-scribble--bl" src="${SCRIBBLE_BL}" alt="" />
            </article>`;

          // Per-article pages (一篇一張 — 但長文章自然 flow 多頁 PDF)
          // body 用完整 markdown → HTML，包含段落 / 標題 / 圖片
          const articlePages = sortedArts
            .map((a) => {
              const bodyHtml = a.contents?.markdown
                ? mdToHtml(a.contents.markdown)
                : `<p class="book-article-fallback">${escapeHtml(a.summary || "（這篇沒有摘要）")}</p>`;
              const dateLine = a.createdAt
                ? `${a.createdAt.slice(0, 4)} 年 ${Number(a.createdAt.slice(5, 7))} 月 ${Number(a.createdAt.slice(8, 10))} 日`
                : "";
              const coverHtml = a.cover
                ? `<div class="book-article-cover"><img src="${escapeHtml(a.cover)}" alt="" loading="lazy" /></div>`
                : "";
              return `
                <article class="book-page book-page--article">
                  <p class="book-page-eyebrow">${escapeHtml(period)} · ${escapeHtml(g.campaign.name)}</p>
                  <h2 class="book-article-title">${escapeHtml(a.title)}</h2>
                  ${coverHtml}
                  <div class="book-article-body">${bodyHtml}</div>
                  <p class="book-article-footer">
                    <span>${escapeHtml(dateLine)}</span>
                    <span class="book-article-source">matters.town/a/${escapeHtml(a.shortHash)}</span>
                  </p>
                </article>`;
            }).join("");

          return divider + articlePages;
        }).join("");

      // ── Closing page：七日書 SVG + scribble + tagline ─────
      const closing = `
        <article class="book-page book-page--closing">
          <img class="book-scribble book-scribble--tr" src="${SCRIBBLE_TR}" alt="" />
          <div class="book-closing-content">
            <p class="book-closing-quote">「下一個七天，<br/>繼續寫。」</p>
            <img class="book-closing-logo" src="${SDB_LOGO_SRC}" alt="七日書" />
            <p class="book-closing-meta">每月一期 · freewriting.matters.town</p>
            <p class="book-closing-credit">Matters 自由寫 × 七日書</p>
          </div>
          <img class="book-scribble book-scribble--bl" src="${SCRIBBLE_BL}" alt="" />
        </article>`;

      return cover + stats + toc + issuePages + closing;
    };

    // ── paged.js 整合：開源 CSS Paged Media polyfill ───────────────
    // 重要踩雷紀錄（一定要寫下來）：
    //   1. paged.js *不會* 自動掃 document.styleSheets 拿 @page 規則。必須
    //      把 @page CSS 透過 preview(content, [stylesheets], target) 第二個
    //      參數明確傳進去（可用 data: URL 把 CSS 字串塞進來），不然 page size
    //      會 fallback 到瀏覽器預設 8.5×11 (US Letter)。
    //   2. 我們原本 .book-page { width:148mm; min-height:210mm; overflow:hidden }
    //      這幾條會讓 paged.js 量不到斷頁、整本書硬塞同一頁。所以要在傳給
    //      paged.js 的 stylesheet 裡用 !important reset 為自然 flow。
    //   3. paged.js 自帶的列印 @media print 規則處理 .pagedjs_page → 列印頁
    //      的對應，我們不用自己處理，放它去就好。
    const BOOK_PAGED_CSS = `
/* @page margin: 0 — 讓 paged.js 的 .pagedjs_page 等於整張 A5，列印時
 * 印表機不會再多加邊界把 paged.js 的 148mm 寬頁切掉右側。
 * 視覺天頭 / 訂口 / 地腳由 .pagedjs_page_content padding 處理。 */
@page {
  size: A5 portrait;
  margin: 0;
}
.pagedjs_page_content {
  padding: 18mm 16mm 22mm !important;
  box-sizing: border-box !important;
}
/* paged.js v0.4.x 對 @bottom-center counter(page) + 自訂 font 有 "item
 * doesn't belong to list" bug，所以頁碼用 JS post-process 注入到
 * .pagedjs_margin-bottom-center .pagedjs_margin-content（見 openBook 末尾） */

/* 把原本手刻的固定 A5 box reset 為 natural flow，paged.js 才能正確斷頁。
 * 注意：padding 用 padding-right/left/bottom 個別歸零，不用 padding 短手，
 * 才能讓 JS post-process 動態加 padding-top 把 divider 上下置中 */
.book-page {
  width: auto !important;
  min-height: 0 !important;
  height: auto !important;
  margin: 0 !important;
  padding-right: 0 !important;
  padding-bottom: 0 !important;
  padding-left: 0 !important;
  border: none !important;
  box-shadow: none !important;
  border-radius: 0 !important;
  background: transparent !important;
  overflow: visible !important;
  break-after: page;
  page-break-after: always;
}
/* 預設 padding-top: 0；divider 由 JS 動態設定 padding-top 達成上下置中 */
.book-page:not(.book-page--divider) {
  padding-top: 0 !important;
}
/* 固定頁不強制 min-height（paged.js 會被 overflow 卡住），讓內容自然填版心 */
.book-page--cover,
.book-page--stats,
.book-page--toc,
.book-page--divider,
.book-page--closing,
.book-page--article {
  display: block !important;
}

/* paged.js v0.4.x 已知 bug：position: absolute 的元素會觸發
 * "item doesn't belong to list" 而中斷分頁。把純裝飾的 abspos 元素關掉。 */
.book-scribble,
.book-divider-art,
.book-divider-mask,
.book-toc-logo {
  display: none !important;
}

/* logo 改 static / inline-block，不要 abspos */
.book-cover-logo,
.book-closing-logo {
  position: static !important;
  display: inline-block !important;
  height: 60px;
  margin: 8mm 0;
}

/* 文章內 figure 圖片放在中間、不要 abspos */
.book-article-fig {
  position: static !important;
  display: block !important;
  margin: 8pt 0;
  text-align: center;
}
.book-article-fig img {
  position: static !important;
  display: inline-block !important;
  max-width: 100%;
  max-height: 60mm;
  height: auto;
}
.book-article-cover {
  position: static !important;
  display: block !important;
  margin: 0 0 8pt;
  text-align: center;
}
.book-article-cover img {
  position: static !important;
  max-width: 100%;
  max-height: 50mm;
  height: auto;
}

/* 取消舊的 ::after 頁碼（已改用 @bottom-center） */
.book-page::after { content: none !important; }

/* 中文書內文版心慣例 — !important 蓋掉 bundled CSS 的 .book-article-body p
 * 注意：中文 + text-align: justify 會把字距拉很開超醜，傳統中文書都是
 * 左對齊 + 段首縮排 2 字。letter-spacing 也不加，避免「文字間隔太散」 */
.book-article-body,
.book-article-body p {
  text-align: left !important;
  text-align-last: auto !important;
  text-justify: auto !important;
  letter-spacing: normal !important;
  word-spacing: normal !important;
}
.book-article-body p {
  margin: 0 0 0.5em !important;
  text-indent: 2em !important;
  font-size: 11pt !important;
  line-height: 1.85 !important;
}
.book-article-body p:first-child,
.book-article-body h3 + p,
.book-article-body figure + p { text-indent: 0 !important; }
.book-article-body h3 {
  margin: 1.2em 0 0.4em !important;
  font-size: 13pt !important;
  font-weight: 600 !important;
  break-after: avoid;
}
.book-article-body blockquote {
  margin: 0.6em 2em !important;
  padding: 0.4em 0.8em !important;
  border-left: 2px solid #c9c4be !important;
  font-style: normal !important;
  break-inside: avoid;
}

/* divider 頁的置中由 JS post-process 處理（見 stampPageNumbers 旁邊的
 * centerDividerPages）。因為 paged.js 用 CSS multi-column 塞 inline style
 * 到 .pagedjs_page_content，CSS 規則蓋不掉。 */
.book-page--divider { text-align: center; }
`;

    const ensurePagedJs = (() => {
      let p = null;
      return () => {
        if (window.PagedPolyfill) return Promise.resolve();
        if (p) return p;
        window.PagedConfig = window.PagedConfig || {};
        window.PagedConfig.auto = false;
        p = new Promise((resolve, reject) => {
          const s = document.createElement("script");
          s.src = "https://unpkg.com/pagedjs@0.4.3/dist/paged.polyfill.js";
          s.onload = () => resolve();
          s.onerror = () => reject(new Error("paged.js 載入失敗"));
          document.head.appendChild(s);
        });
        return p;
      };
    })();

    // paged.js 對 abspos 子節點 / 部分 <img> / SVG cover 不穩，會中斷分頁。
    // 用 DOMParser 把書 HTML 過濾乾淨：拿掉所有裝飾元素 + 圖片，留純文字版心，
    // 這樣 paged.js 走得順、頁數正確、書頁讀得下。
    const sanitizeBookForPagedJs = (html) => {
      const doc = new DOMParser().parseFromString(`<div>${html}</div>`, "text/html");
      const root = doc.body.firstElementChild;
      // 一律移除所有圖片 (<img>, <svg>, <picture>) 與裝飾性 div
      root
        .querySelectorAll(
          "img, svg, picture, .book-scribble, .book-divider-art, .book-divider-mask, .book-toc-logo, .book-article-cover, .book-article-fig",
        )
        .forEach((el) => el.remove());
      // figcaption 留下作圖說（但若 figure 已被移除就 noop）
      return root.innerHTML;
    };

    // paged.js 用 CSS multi-column 把內容切到 .pagedjs_page_content，會在中間
    // 塞一個 anonymous <div>，所以 flex 鏈斷掉、CSS 怎麼寫都不能讓 .book-page--divider
    // 上下置中。改 post-process：找出每個 divider 計算 padding-top 把內容推到中間。
    const centerDividerPages = (target) => {
      target.querySelectorAll(".pagedjs_page").forEach((p) => {
        const divider = p.querySelector(".book-page--divider");
        if (!divider) return;
        const pageContent = p.querySelector(".pagedjs_page_content");
        if (!pageContent) return;
        const totalH = pageContent.getBoundingClientRect().height;
        const contentH = divider.getBoundingClientRect().height;
        if (contentH >= totalH) return;
        const padding = Math.max(0, (totalH - contentH) / 2);
        divider.style.paddingTop = `${padding}px`;
      });
    };

    // paged.js v0.4.x 不能用 @bottom-center counter(page) (會炸 item doesn't
     // belong to list)，所以頁碼用 DOM 後處理：每張 .pagedjs_page 加一個 abspos
     // 的 div 在底部置中，封面 (page 1) 不放
    const stampPageNumbers = (target) => {
      const pages = target.querySelectorAll(".pagedjs_page");
      pages.forEach((p, i) => {
        if (i === 0) return; // 封面不放頁碼
        if (p.querySelector(".book-page-number")) return; // 已加過
        const num = document.createElement("div");
        num.className = "book-page-number";
        num.textContent = String(i + 1);
        num.setAttribute("aria-hidden", "true");
        const pagebox = p.querySelector(".pagedjs_pagebox") || p;
        if (getComputedStyle(pagebox).position === "static") {
          pagebox.style.position = "relative";
        }
        pagebox.appendChild(num);
      });
    };

    // 把 BOOK_PAGED_CSS 同時注入到：
    //  (a) <head><style> — 確保最終渲染後的 .pagedjs_page_* 都應用到
    //  (b) PagedPolyfill.preview(_, [dataUrl], _) — 讓 paged.js 在 chunk
    //      時也讀得到 @page rule
    const ensureBookCss = (() => {
      let added = false;
      return () => {
        if (added) return;
        const style = document.createElement("style");
        style.id = "book-paged-css";
        style.textContent = BOOK_PAGED_CSS;
        document.head.appendChild(style);
        added = true;
      };
    })();

    const openBook = async () => {
      if (!lastJourney || !bookModal) return;
      bookModal.removeAttribute("hidden");
      document.body.classList.add("book-open");
      document.body.style.overflow = "hidden";
      bookPagesEl.innerHTML = `<p class="book-modal__placeholder" aria-busy="true">正在排版你的小書，A5 開本中…（首次需 2-5 秒）</p>`;
      try {
        await ensurePagedJs();
        ensureBookCss();
        const rawHtml = buildBookHtml(lastJourney);
        const cleanHtml = sanitizeBookForPagedJs(rawHtml);
        const wrapper = document.createElement("div");
        wrapper.className = "book-source";
        wrapper.innerHTML = cleanHtml;
        bookPagesEl.innerHTML = "";
        const cssUrl = `data:text/css;charset=utf-8,${encodeURIComponent(BOOK_PAGED_CSS)}`;
        await window.PagedPolyfill.preview(wrapper, [cssUrl], bookPagesEl);
        stampPageNumbers(bookPagesEl);
        centerDividerPages(bookPagesEl);
        bookPagesEl.scrollTop = 0;
      } catch (e) {
        console.warn("paged.js 失敗，回退到簡易 preview：", e);
        bookPagesEl.innerHTML = `<div class="book-source">${buildBookHtml(lastJourney)}</div>`;
      }
    };
    const closeBook = () => {
      if (!bookModal) return;
      bookModal.setAttribute("hidden", "");
      document.body.classList.remove("book-open");
      document.body.style.overflow = "";
    };

    document.querySelectorAll("[data-close-book]").forEach((el) => {
      el.addEventListener("click", closeBook);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && bookModal && !bookModal.hasAttribute("hidden")) {
        closeBook();
      }
    });
    // 列印：直接 sync call window.print()。之前 rAF 包兩層會被 Chromium /
    // Safari 的 popup blocker 視為「非使用者觸發」而靜默吃掉。
    printBtn?.addEventListener("click", () => {
      window.print();
    });

    // ── EPUB 3 builder: 純 client-side zip，不靠 paged.js（reflowable
    //    閱讀，Apple Books / Kobo / Calibre 都能開）─────────────────
    const ensureJSZip = (() => {
      let p = null;
      return () => {
        if (window.JSZip) return Promise.resolve();
        if (p) return p;
        p = new Promise((resolve, reject) => {
          const s = document.createElement("script");
          s.src = "https://unpkg.com/jszip@3.10.1/dist/jszip.min.js";
          s.onload = () => resolve();
          s.onerror = () => reject(new Error("JSZip 載入失敗"));
          document.head.appendChild(s);
        });
        return p;
      };
    })();

    const escapeXml = (s) =>
      String(s ?? "").replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&apos;" }[c])
      );

    // EPUB 中文書版心 CSS — reflowable 給閱讀器自己處理斷頁，不需要 @page
    const BOOK_EPUB_CSS = `
@charset "UTF-8";
body {
  font-family: "PingFang TC", "Noto Serif TC", "Source Han Serif TC", serif;
  line-height: 1.85;
  margin: 0;
  padding: 1em;
  color: #2b2926;
}
h1, h2, h3 {
  font-weight: 600;
  margin: 1.2em 0 0.5em;
  page-break-after: avoid;
  break-after: avoid;
}
h1 { font-size: 1.6em; text-align: center; margin-top: 2em; }
h2 { font-size: 1.3em; }
h3 { font-size: 1.1em; }
p {
  margin: 0 0 0.4em;
  text-indent: 2em;
  text-align: left;
}
p:first-child, h1 + p, h2 + p, h3 + p, figure + p, .eyebrow + p, .eyebrow + h1, .eyebrow + h2 { text-indent: 0; }
.eyebrow {
  display: block;
  color: #666;
  font-size: 0.9em;
  letter-spacing: 0.06em;
  text-indent: 0;
  margin: 0 0 0.4em;
}
.center { text-align: center; text-indent: 0; }
.handle, .date, .meta { text-align: center; color: #666; text-indent: 0; }
blockquote {
  margin: 0.6em 1.5em;
  padding: 0.4em 0.8em;
  border-left: 3px solid #c9c4be;
  color: #555;
}
blockquote p { text-indent: 0; }
section.cover { text-align: center; margin-top: 4em; }
section.cover h1 { font-size: 2em; }
section.divider { text-align: center; margin-top: 3em; page-break-before: always; break-before: page; }
section.divider h2 { font-size: 1.5em; margin: 0.6em 0; }
section.closing { text-align: center; margin-top: 3em; page-break-before: always; break-before: page; }
.toc-item { margin: 0.3em 0; }
.toc-num { display: inline-block; width: 2.5em; color: #045898; font-weight: 600; }
`;

    const xhtml = (body, title) =>
      `<?xml version="1.0" encoding="UTF-8"?>\n` +
      `<!DOCTYPE html>\n` +
      `<html xmlns="http://www.w3.org/1999/xhtml" xmlns:epub="http://www.idpf.org/2007/ops" lang="zh-Hant">\n` +
      `<head>\n` +
      `  <meta charset="UTF-8"/>\n` +
      `  <title>${escapeXml(title || "")}</title>\n` +
      `  <link rel="stylesheet" type="text/css" href="styles/book.css"/>\n` +
      `</head>\n` +
      `<body>\n${body}\n</body>\n</html>\n`;

    // markdown / Matters HTML → EPUB 友善 XHTML
    // 跟 PDF 用的 mdToHtml 邏輯類似，但保留 figure 圖片（EPUB reader 處理得很好），
    // 同時把所有 inline HTML tag 收乾淨，避免 XHTML parse error
    const mdToEpubXhtml = (md) => {
      if (!md) return "";
      const { text, figures } = extractFigures(md);
      const blocks = text.replace(/FIG(\d+)/g, "\n\nFIG$1\n\n").split(/\n\s*\n+/);
      return blocks
        .map((blk) => {
          const t = blk.trim();
          if (!t) return "";
          const figMatch = t.match(/^FIG(\d+)$/);
          if (figMatch) {
            const f = figures[Number(figMatch[1])];
            if (!f) return "";
            // EPUB 閱讀器普遍允許外連 https://，但保險起見只放 alt + caption
            const cap = f.caption ? `<figcaption>${escapeXml(f.caption)}</figcaption>` : "";
            return `<figure><img src="${escapeXml(f.src)}" alt="${escapeXml(f.alt)}"/>${cap}</figure>`;
          }
          const h = t.match(/^(#{1,6})\s+(.+)$/);
          if (h) {
            const txt = escapeXml(stripInlineHtml(h[2]).replace(/[*_`]/g, "").trim());
            if (!txt) return "";
            return `<h3>${txt}</h3>`;
          }
          if (t.startsWith("> ")) {
            const q = escapeXml(
              stripInlineHtml(t.slice(2))
                .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
                .replace(/[*_`]/g, "")
                .trim()
            );
            if (!q) return "";
            return `<blockquote><p>${q}</p></blockquote>`;
          }
          const cleaned = stripInlineHtml(t)
            .replace(/!\[[^\]]*\]\([^)]+\)/g, "")
            .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
            .replace(/\*\*([^*]+)\*\*/g, "$1")
            .replace(/\*([^*]+)\*/g, "$1")
            .replace(/`([^`]+)`/g, "$1")
            .trim();
          if (!cleaned) return "";
          const escaped = escapeXml(cleaned).replace(/\n+/g, "<br/>");
          return `<p>${escaped}</p>`;
        })
        .filter(Boolean)
        .join("\n");
    };

    const triggerDownload = (blob, filename) => {
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    };

    const buildEpub = async (journey) => {
      await ensureJSZip();
      const zip = new window.JSZip();
      const { user, groups, totalArticles } = journey;
      const today = new Date();
      const dateStr = `${today.getFullYear()} 年 ${today.getMonth() + 1} 月 ${today.getDate()} 日`;
      const bookTitle = `${user.displayName} 的七日書小書`;
      const author = `@${user.userName}`;
      const bookId = "urn:uuid:" + (crypto.randomUUID
        ? crypto.randomUUID()
        : Date.now() + "-" + Math.random().toString(36).slice(2));
      const isoDate = today.toISOString().split(".")[0] + "Z";

      // mimetype 必須第一個 + uncompressed (EPUB spec)
      zip.file("mimetype", "application/epub+zip", { compression: "STORE" });

      // META-INF
      zip.file(
        "META-INF/container.xml",
        `<?xml version="1.0" encoding="UTF-8"?>\n` +
          `<container version="1.0" xmlns="urn:oasis:names:tc:opendocument:xmlns:container">\n` +
          `  <rootfiles>\n` +
          `    <rootfile full-path="OEBPS/content.opf" media-type="application/oebps-package+xml"/>\n` +
          `  </rootfiles>\n` +
          `</container>\n`
      );

      // styles
      zip.file("OEBPS/styles/book.css", BOOK_EPUB_CSS);

      // 收集 chapter 用 (id / href / title)
      const chapters = [];

      // cover
      chapters.push({ id: "cover", href: "cover.xhtml", title: "封面" });
      zip.file(
        "OEBPS/cover.xhtml",
        xhtml(
          `<section class="cover">\n` +
            `  <p class="eyebrow">Matters · 自由寫</p>\n` +
            `  <h1>${escapeXml(bookTitle)}</h1>\n` +
            `  <p class="handle">${escapeXml(author)}</p>\n` +
            `  <p class="date">${escapeXml(dateStr)} 編製</p>\n` +
            `</section>`,
          bookTitle
        )
      );

      // stats
      const firstYear = groups.length
        ? formatMonthLabel(groups[groups.length - 1].articles[0].createdAt).split(" 年")[0]
        : "—";
      chapters.push({ id: "stats", href: "stats.xhtml", title: "這幾年的書寫" });
      zip.file(
        "OEBPS/stats.xhtml",
        xhtml(
          `<section class="cover">\n` +
            `  <p class="eyebrow">這幾年的書寫</p>\n` +
            `  <h2 class="center">${groups.length} 期七日書 · ${totalArticles} 篇文章</h2>\n` +
            `  <p class="meta">第一次參與：${escapeXml(firstYear)}</p>\n` +
            `  <p class="meta">每一篇都是一個七天裡安靜的下午。</p>\n` +
            `</section>`,
          "這幾年的書寫"
        )
      );

      // For each issue: divider + per-article xhtml
      groups.forEach((g, i) => {
        const idx = String(i + 1).padStart(2, "0");
        const sortedArts = [...g.articles].sort(
          (a, b) => +new Date(a.createdAt) - +new Date(b.createdAt)
        );
        const period = formatMonthLabel(sortedArts[0].createdAt);

        // divider
        const dividerId = `ch${idx}-divider`;
        chapters.push({
          id: dividerId,
          href: `${dividerId}.xhtml`,
          title: g.campaign.name,
        });
        zip.file(
          `OEBPS/${dividerId}.xhtml`,
          xhtml(
            `<section class="divider">\n` +
              `  <p class="eyebrow">第 ${idx} 站</p>\n` +
              `  <p class="meta">${escapeXml(period)}</p>\n` +
              `  <h2>${escapeXml(g.campaign.name)}</h2>\n` +
              `  <p class="meta">在這期，你寫了 ${sortedArts.length} 篇</p>\n` +
              `</section>`,
            g.campaign.name
          )
        );

        // articles
        sortedArts.forEach((a, j) => {
          const artId = `ch${idx}-art${String(j + 1).padStart(2, "0")}`;
          const bodyHtml = a.contents?.markdown
            ? mdToEpubXhtml(a.contents.markdown)
            : `<p>${escapeXml(a.summary || "")}</p>`;
          const dateLine = a.createdAt
            ? `${a.createdAt.slice(0, 4)} 年 ${Number(a.createdAt.slice(5, 7))} 月 ${Number(a.createdAt.slice(8, 10))} 日`
            : "";
          chapters.push({ id: artId, href: `${artId}.xhtml`, title: a.title });
          zip.file(
            `OEBPS/${artId}.xhtml`,
            xhtml(
              `<section>\n` +
                `  <p class="eyebrow">${escapeXml(period)} · ${escapeXml(g.campaign.name)}</p>\n` +
                `  <h2>${escapeXml(a.title)}</h2>\n` +
                bodyHtml +
                `\n  <p class="meta">${escapeXml(dateLine)} · matters.town/a/${escapeXml(a.shortHash)}</p>\n` +
                `</section>`,
              a.title
            )
          );
        });
      });

      // closing
      chapters.push({ id: "closing", href: "closing.xhtml", title: "封底" });
      zip.file(
        "OEBPS/closing.xhtml",
        xhtml(
          `<section class="closing">\n` +
            `  <p class="eyebrow">「下一個七天，繼續寫。」</p>\n` +
            `  <h2 class="center">Matters 自由寫 × 七日書</h2>\n` +
            `  <p class="meta">每月一期 · freewriting.matters.town</p>\n` +
            `</section>`,
          "封底"
        )
      );

      // toc.xhtml (EPUB 3 nav)
      const navList = chapters
        .map((c) => `      <li><a href="${escapeXml(c.href)}">${escapeXml(c.title)}</a></li>`)
        .join("\n");
      zip.file(
        "OEBPS/toc.xhtml",
        xhtml(
          `<nav epub:type="toc" id="toc">\n` +
            `  <h1>目錄</h1>\n` +
            `  <ol>\n${navList}\n  </ol>\n` +
            `</nav>`,
          "目錄"
        )
      );

      // toc.ncx (legacy NCX, 給舊閱讀器)
      const navPoints = chapters
        .map(
          (c, i) =>
            `  <navPoint id="np-${c.id}" playOrder="${i + 1}">\n` +
            `    <navLabel><text>${escapeXml(c.title)}</text></navLabel>\n` +
            `    <content src="${escapeXml(c.href)}"/>\n` +
            `  </navPoint>`
        )
        .join("\n");
      zip.file(
        "OEBPS/toc.ncx",
        `<?xml version="1.0" encoding="UTF-8"?>\n` +
          `<ncx version="2005-1" xmlns="http://www.daisy.org/z3986/2005/ncx/">\n` +
          `  <head>\n` +
          `    <meta name="dtb:uid" content="${bookId}"/>\n` +
          `    <meta name="dtb:depth" content="1"/>\n` +
          `    <meta name="dtb:totalPageCount" content="0"/>\n` +
          `    <meta name="dtb:maxPageNumber" content="0"/>\n` +
          `  </head>\n` +
          `  <docTitle><text>${escapeXml(bookTitle)}</text></docTitle>\n` +
          `  <docAuthor><text>${escapeXml(author)}</text></docAuthor>\n` +
          `  <navMap>\n${navPoints}\n  </navMap>\n` +
          `</ncx>\n`
      );

      // content.opf
      const manifestItems = chapters
        .map(
          (c) =>
            `    <item id="${c.id}" href="${escapeXml(c.href)}" media-type="application/xhtml+xml"/>`
        )
        .join("\n");
      const spineItems = chapters
        .map((c) => `    <itemref idref="${c.id}"/>`)
        .join("\n");
      zip.file(
        "OEBPS/content.opf",
        `<?xml version="1.0" encoding="UTF-8"?>\n` +
          `<package version="3.0" xmlns="http://www.idpf.org/2007/opf" unique-identifier="bookid">\n` +
          `  <metadata xmlns:dc="http://purl.org/dc/elements/1.1/">\n` +
          `    <dc:identifier id="bookid">${escapeXml(bookId)}</dc:identifier>\n` +
          `    <dc:title>${escapeXml(bookTitle)}</dc:title>\n` +
          `    <dc:creator>${escapeXml(author)}</dc:creator>\n` +
          `    <dc:language>zh-Hant</dc:language>\n` +
          `    <dc:publisher>Matters · 自由寫</dc:publisher>\n` +
          `    <meta property="dcterms:modified">${isoDate}</meta>\n` +
          `  </metadata>\n` +
          `  <manifest>\n` +
          `    <item id="ncx" href="toc.ncx" media-type="application/x-dtbncx+xml"/>\n` +
          `    <item id="nav" href="toc.xhtml" media-type="application/xhtml+xml" properties="nav"/>\n` +
          `    <item id="css" href="styles/book.css" media-type="text/css"/>\n` +
          `${manifestItems}\n` +
          `  </manifest>\n` +
          `  <spine toc="ncx">\n` +
          `    <itemref idref="nav"/>\n` +
          `${spineItems}\n` +
          `  </spine>\n` +
          `</package>\n`
      );

      return await zip.generateAsync({
        type: "blob",
        mimeType: "application/epub+zip",
        compression: "DEFLATE",
        compressionOptions: { level: 6 },
      });
    };

    epubBtn?.addEventListener("click", async () => {
      if (!lastJourney) return;
      const orig = epubBtn.textContent;
      epubBtn.disabled = true;
      epubBtn.textContent = "打包中…";
      try {
        const blob = await buildEpub(lastJourney);
        const fname = `${lastJourney.user.userName}-七日書小書.epub`;
        triggerDownload(blob, fname);
      } catch (e) {
        console.error("EPUB 打包失敗", e);
        alert("EPUB 打包失敗：" + (e.message || e));
      } finally {
        epubBtn.disabled = false;
        epubBtn.textContent = orig;
      }
    });

    const renderError = (msg) => {
      passportResult.innerHTML = `
        <div class="passport-empty">
          <h3>查詢沒成功</h3>
          <p>${escapeHtml(msg)}</p>
        </div>`;
      lastJourney = null;
    };

    const renderLoading = () => {
      passportResult.innerHTML = `<p class="passport-loading" aria-busy="true">正在向 Matters 詢問你的書寫足跡…</p>`;
    };

    const runSearch = async (handle) => {
      const clean = (handle || "").replace(/^@/, "").replace(/^https?:\/\/[^/]+\/@?/, "").trim();
      if (!clean) return;
      if (passportInput) passportInput.value = clean;
      renderLoading();
      try {
        const user = await fetchUserArticles(clean);
        renderResult(user);
      } catch (err) {
        renderError(err.message || String(err));
      }
    };

    passportForm?.addEventListener("submit", (e) => {
      e.preventDefault();
      runSearch(passportInput?.value || "");
    });

    // 點選馬拉松選手 → 滾到 passport + 自動填入帳號 + 觸發查詢
    document.querySelectorAll("[data-marathoner-handle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const handle = btn.getAttribute("data-marathoner-handle");
        if (!handle) return;
        const sec = document.getElementById("my-journey");
        sec?.scrollIntoView({ behavior: "smooth", block: "start" });
        runSearch(handle);
      });
    });

    // ── 名家講座：查看更多 / 收合 ─────────────────────────
    (() => {
      const grid = document.querySelector("[data-lecture-grid]");
      const btn = document.querySelector("[data-lecture-expand]");
      const label = document.querySelector("[data-lecture-expand-label]");
      if (!grid || !btn || !label) return;
      const initial = Number(grid.getAttribute("data-initial") || "6");
      const items = Array.from(grid.querySelectorAll("[data-lecture-item]"));
      const hiddenCount = items.length - initial;
      if (hiddenCount <= 0) {
        btn.setAttribute("hidden", "");
        return;
      }
      label.textContent = `展開更多 ${hiddenCount} 位講者 ↓`;
      let expanded = false;
      btn.addEventListener("click", () => {
        expanded = !expanded;
        items.forEach((card, idx) => {
          if (idx < initial) return;
          if (expanded) card.removeAttribute("hidden");
          else card.setAttribute("hidden", "");
        });
        btn.setAttribute("aria-expanded", expanded ? "true" : "false");
        label.textContent = expanded ? "收合 ↑" : `展開更多 ${hiddenCount} 位講者 ↓`;
        if (!expanded) {
          grid.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    })();

    // ── 本月七題：依今天日期即時更新狀態 pill + 進度 ─────────
    // 寫死的 prompt.state（"past"/"today"/"locked"）只是資料快照，會過時。
    // 這邊每次載入頁面用 client-side 算「今天距該日 N 天」推回真實狀態：
    //   delta < 0 → 已開放 N 天（過去）
    //   delta == 0 → 今日 · 進行中（今天）
    //   delta == 1 → 明天開放
    //   delta > 1 → N 天後開放
    (() => {
      const cards = document.querySelectorAll("[data-day-card]");
      if (!cards.length) return;
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const todayMs = today.getTime();

      let pastCount = 0;
      let todayIso = null;

      cards.forEach((card) => {
        const iso = card.getAttribute("data-day-iso");
        if (!iso) return;
        const promptDate = new Date(iso + "T00:00:00");
        const deltaDays = Math.round((promptDate.getTime() - todayMs) / 86400000);
        const status = card.querySelector("[data-day-status]");

        let label, stateClass;
        if (deltaDays < 0) {
          label = `已開放 ${Math.abs(deltaDays)} 天`;
          stateClass = "day-unlock-card--past";
          pastCount++;
        } else if (deltaDays === 0) {
          label = "今日 · 進行中";
          stateClass = "day-unlock-card--today";
          todayIso = iso;
        } else if (deltaDays === 1) {
          label = "明天開放";
          stateClass = "day-unlock-card--locked";
        } else {
          label = `${deltaDays} 天後開放`;
          stateClass = "day-unlock-card--locked";
        }
        if (status) status.textContent = label;
        card.classList.remove(
          "day-unlock-card--past",
          "day-unlock-card--today",
          "day-unlock-card--locked"
        );
        card.classList.add(stateClass);
      });

      // 整體進度條文案（本期已進行 N / 7 天 / 即將開始 / 已結束）
      const progressEl = document.querySelector("[data-issue-progress-text]");
      if (progressEl) {
        const total = cards.length;
        if (todayIso) {
          progressEl.textContent = `本期已進行 ${pastCount + 1} / ${total} 天 · 今日題目正在進行中`;
        } else if (pastCount === 0) {
          // 還沒開始
          const firstCard = cards[0];
          const firstIso = firstCard?.getAttribute("data-day-iso");
          const startDays = firstIso
            ? Math.round((new Date(firstIso + "T00:00:00").getTime() - todayMs) / 86400000)
            : 0;
          progressEl.textContent =
            startDays === 1 ? `本期明天開始` : `本期 ${startDays} 天後開始`;
        } else if (pastCount >= total) {
          // 已結束
          progressEl.textContent = `本期已結束 · 共 ${total} 天 ${total} 道題目`;
        } else {
          progressEl.textContent = `本期已進行 ${pastCount} / ${total} 天`;
        }
      }
    })();

    // ── 馬拉松選手：查看更多 / 收合 ─────────────────────────
    (() => {
      const grid = document.querySelector("[data-marathoner-grid]");
      const btn = document.querySelector("[data-marathoner-expand]");
      const label = document.querySelector("[data-marathoner-expand-label]");
      if (!grid || !btn || !label) return;
      const initial = Number(grid.getAttribute("data-initial") || "15");
      const items = Array.from(grid.querySelectorAll("[data-marathoner-item]"));
      const hiddenCount = items.length - initial;
      if (hiddenCount <= 0) {
        btn.setAttribute("hidden", "");
        return;
      }
      label.textContent = `查看更多長跑選手（還有 ${hiddenCount} 位） ↓`;
      let expanded = false;
      btn.addEventListener("click", () => {
        expanded = !expanded;
        items.forEach((li, idx) => {
          if (idx < initial) return;
          if (expanded) li.removeAttribute("hidden");
          else li.setAttribute("hidden", "");
        });
        btn.setAttribute("aria-expanded", expanded ? "true" : "false");
        label.textContent = expanded
          ? "收合 ↑"
          : `查看更多長跑選手（還有 ${hiddenCount} 位） ↓`;
        if (!expanded) {
          grid.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    })();

    // ── 歷年精選文章：chip filter + show-more ───────────────────
    (() => {
      const grid = document.querySelector("[data-featured-grid]");
      const chipsRoot = document.querySelector("[data-featured-chips]");
      const moreBtn = document.querySelector("[data-featured-more]");
      const moreLabel = document.querySelector("[data-featured-more-label]");
      if (!grid || !chipsRoot || !moreBtn || !moreLabel) return;
      const initial = Number(grid.getAttribute("data-initial") || "12");
      const STEP = 12;
      const cards = Array.from(grid.querySelectorAll("[data-featured-card]"));
      let activeFilter = "all";
      let visibleCount = initial;

      const apply = () => {
        const matched = cards.filter(
          (c) => activeFilter === "all" || c.getAttribute("data-campaign") === activeFilter,
        );
        const total = matched.length;
        let shown = 0;
        // hide all
        cards.forEach((c) => c.setAttribute("hidden", ""));
        // show first N of matched
        matched.slice(0, visibleCount).forEach((c) => {
          c.removeAttribute("hidden");
          shown++;
        });
        if (shown >= total) {
          moreBtn.setAttribute("hidden", "");
        } else {
          moreBtn.removeAttribute("hidden");
          moreLabel.textContent = `展開更多 ${Math.min(STEP, total - shown)} 篇 ↓`;
        }
      };

      chipsRoot.querySelectorAll("[data-chip-target]").forEach((chip) => {
        chip.addEventListener("click", () => {
          const target = chip.getAttribute("data-chip-target") || "all";
          // 點到目前已選中的 chip → 視為取消篩選，回到「全部」
          if (chip.classList.contains("featured-chip--active")) {
            chip.classList.remove("featured-chip--active");
            activeFilter = "all";
          } else {
            chipsRoot
              .querySelectorAll("[data-chip-target]")
              .forEach((c) => c.classList.remove("featured-chip--active"));
            chip.classList.add("featured-chip--active");
            activeFilter = target;
          }
          visibleCount = initial; // reset pagination when changing filter
          apply();
          grid.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      moreBtn.addEventListener("click", () => {
        visibleCount += STEP;
        apply();
      });

      apply();
    })();
  </script>
</BaseLayout>
