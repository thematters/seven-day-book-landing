---
// 金句牆 Memo Wall —— 七日書博物館的「大牆」（網址 /museum/memo-wall/）
// 資料來源：src/data/quote-wall.ts（由 scripts/fetch-quote-wall.mjs 定期重抓
//   各期七日書 WritingChallenge.quotes —— 文友在站上實際「選」出來的金句）。
import BaseLayout from "../../layouts/BaseLayout.astro";
import MattersWordmark from "../../components/MattersWordmark.astro";
import SevenDayBookLogo from "../../components/SevenDayBookLogo.astro";
import { quoteWall, quoteWallCount } from "../../data/quote-wall";
import { communityQuotes } from "../../data/community-quotes";
import { withBase } from "../../utils/paths";
import { memoWallCurrent } from "../../data/memo-wall-current";

const museumHref = withBase("museum/");
const homeHref = withBase(""); // 七日書介紹（首頁）
const partnersHref = withBase("partnership/"); // 合作洽談
const currentIssueHref = `${museumHref}#current-issue`;

// 可上金句牆的歷期（= museum.astro 的 eligibleCampaignHashes，enableQuoteWall 的活動），新 → 舊排。
// hash 用來組活動頁連結 matters.town/e/{hash}。「本期」不寫死在這，改讀 memo-wall-current.ts（見下）。
// name = 正式標題；hash = 活動頁；href = 公告頁（最早 3 期沒有活動頁）；month = 活動寫作月份。
const CAMPAIGNS: { name: string; hash: string; href?: string; month: string }[] = [
  { name: "無用之用", hash: "nxy5zqcjs7lt", month: "2026 年 6 月" },
  { name: "我的職場人格", hash: "wem6xy6u7okv", month: "2026 年 5 月" },
  { name: "氣味博物館", hash: "aiafcgbu89p2", month: "2026 年 4 月" },
  { name: "我的人生帳本", hash: "q48dv6ve4g2m", month: "2026 年 3 月" },
  { name: "數位雲端的我", hash: "4v5mndkbz44v", month: "2026 年 2 月" },
  { name: "衣櫥裡的自我", hash: "nqbeo3cdn585", month: "2026 年 1 月" },
  { name: "說聲告別，走向新的自己", hash: "ox9fmcz6zxxj", month: "2025 年 12 月" },
  { name: "重構生活", hash: "3uskpxsbzmz5", month: "2025 年 11 月" },
  { name: "曖昧時刻", hash: "owt3jxplay6z", month: "2025 年 10 月" },
  { name: "標記回憶的位置與意義", hash: "rt04oolqbexh", month: "2025 年 9 月" },
  { name: "關於人生，我想說的是", hash: "5zhf2bpty274", month: "2025 年 8 月" },
  { name: "長女症候群，燃燒自我的故事", hash: "h2ya9xxjubd2", month: "2025 年 7 月" },
  { name: "What if 人生有如果", hash: "efkk0l9hcg96", month: "2025 年 6 月" },
  { name: "書寫人生的靈魂提問", hash: "26uhbm3uh6rg", month: "2025 年 5 月" },
  { name: "書寫地方", hash: "4nqnizsygmcn", month: "2025 年 4 月" },
  { name: "我的家庭故事", hash: "f7rpyecg32mg", month: "2025 年 3 月" },
  { name: "人間鬼故事", hash: "x4rv6dwgk68o", month: "2025 年 2 月" },
  { name: "我的（不）完美人生", hash: "eqsfuc3qph6u", month: "2025 年 1 月" },
  { name: "物的體系，我的物件錄", hash: "8t5liudbtpup", month: "2024 年 12 月" },
  { name: "島嶼精神，另類人生", hash: "scx3f16y37v6", month: "2024 年 11 月" },
  { name: "我的成長軌跡", hash: "ia800figcq9y", month: "2024 年 9 月" },
  { name: "我的人生飯桌", hash: "5sdzhvyf3imb", month: "2024 年 8 月" },
  // 最早 3 期：資料裡只有公告頁、沒有活動頁，按鈕連公告頁、文案改「閱讀當期公告」
  { name: "愛與親密關係", hash: "", href: "https://matters.town/a/kbv6vz8uhxb8", month: "2024 年 7 月" },
  { name: "家與故鄉", hash: "", href: "https://matters.town/a/u3qna0i5t2m5", month: "2024 年 6 月" },
  { name: "空間與地方", hash: "", href: "https://matters.town/a/e6tu274xo8q1", month: "2024 年 4 月" },
];
const pastCampaigns = CAMPAIGNS;
const orderOf = new Map(CAMPAIGNS.map((c, i) => [c.name, i]));

// 本期 = 金句牆自己的設定（memo-wall-current.ts），跟博物館 currentIssue 拆開。
// 每出新活動只改 memo-wall-current.ts 那三行，金句牆更新、博物館首頁不受影響。
const currentName = memoWallCurrent.title;
const currentEvent = memoWallCurrent.eventHref;
const currentMonth = memoWallCurrent.month;
const CURRENT_KEY = "__current__"; // 篩選用：代表「本期」那顆籤與釘住的便利貼
// 金句的 campaignName（可能含「七日書｜」「，另類人生」等）對到歷期清單裡的標準名
const campaignKey = (label: string) => {
  const hit = pastCampaigns.find(
    (c) => label.includes(c.name) || c.name.includes(label),
  );
  return hit ? hit.name : label;
};
// 期的活動頁連結：優先用明確 href（最早 3 期暫連公告頁），否則 /e/{hash}，再否則本月七題
const campaignHref = (c: { hash: string; href?: string }) =>
  c.href ? c.href : c.hash ? `https://matters.town/e/${c.hash}` : currentIssueHref;
const articleUrl = (hash: string) =>
  hash ? `https://matters.town/a/${hash}` : "#";

// quote-wall.ts 目前空的（金句牆 2026/7 才上線）。先用 community-quotes.ts 的現成
// 金句當『範例資料』把牆撐起來。⚠️ 上線前要拿掉 SAMPLE，只吃 quoteWall。
const SAMPLE_COUNT = 50; // 預覽用：把現有範例句循環成 50 張，純看牆的密度
const usingSample = quoteWallCount === 0;
const rawSource = usingSample
  ? Array.from({ length: SAMPLE_COUNT }, (_, i) => {
      const q = communityQuotes[i % communityQuotes.length];
      return {
        id: `s-${i}`,
        content: q.text,
        author: q.author,
        campaignName: q.campaignLabel,
        articleHash: q.articleHash,
      };
    })
  : quoteWall.map((q) => ({
      id: q.id,
      content: q.content,
      author: q.author,
      campaignName: q.campaignName,
      articleHash: q.articleHash,
    }));

// 把金句歸到標準期名，並依期數新 → 舊排
const wallQuotes = rawSource
  .map((q) => ({ ...q, key: campaignKey(q.campaignName) }))
  .sort((a, b) => (orderOf.get(a.key) ?? 99) - (orderOf.get(b.key) ?? 99));

// 歷屆（不含本期）依年份分組，給「瀏覽歷屆」下拉用（新 → 舊）
const yearOf = (m: string) => m.match(/(\d{4})/)?.[1] ?? "";
const pastForSelect = CAMPAIGNS.filter((c) => c.name !== currentName);
const campaignsByYear = [...new Set(pastForSelect.map((c) => yearOf(c.month)))]
  .sort()
  .reverse()
  .map((year) => ({
    year,
    items: pastForSelect.filter((c) => yearOf(c.month) === year),
  }));

const title = "金句牆｜七日書博物館";
const description = "文友親手摘下的金句，跨屆典藏在這面牆上。";
---

<BaseLayout title={title} description={description}>
  <h1 class="sr-only">金句牆 — 七日書博物館</h1>

  <!-- 頂部選單：博物館各區塊（與 museum.astro 同步），博物館排第一 -->
  <header class="wall-nav">
    <a class="wall-nav__brand" href={museumHref} aria-label="七日書博物館・金句牆">
      <SevenDayBookLogo size={40} title="七日書" className="wall-nav__logo" />
      <span class="wall-nav__brand-text">金句牆</span>
    </a>
    <nav class="wall-nav__links" aria-label="七日書博物館導覽">
      <a href={museumHref}>博物館</a>
      <a href={`${museumHref}#marathoners`}>名人堂</a>
      <a href={`${museumHref}#my-journey`}>我的旅程</a>
      <a href={currentIssueHref}>本月七題</a>
      <a href={`${museumHref}#featured`}>歷年精選</a>
      <a href={`${museumHref}#lectures`}>名家講座</a>
      <a href={homeHref}>七日書介紹</a>
      <a href={partnersHref}>合作洽談</a>
    </nav>
    <a
      class="wall-nav__matters"
      href="https://matters.town"
      target="_blank"
      rel="noopener"
      aria-label="Matters"
    >
      <MattersWordmark size={15} />
    </a>
  </header>

  <main class="wall-page">
    <!-- 控制列：全部／本期 兩顆籤 + 歷屆收進下拉（清爽、桌機手機一致） -->
    <section class="wall-controls">
      <div class="wall-filters" id="filters" role="group" aria-label="篩選金句">
        <button class="wall-filter is-on" data-campaign="" type="button">全部</button>
        <button
          class="wall-filter wall-filter--now"
          data-campaign={CURRENT_KEY}
          data-event={currentEvent}
          type="button">✦ {currentName}・本期</button>
        <select class="wall-select" id="campaign-select" aria-label="瀏覽過往主題">
          <option value="">瀏覽過往主題⋯</option>
          {
            campaignsByYear.map((g) => (
              <optgroup label={`${g.year} 年`}>
                {g.items.map((c) => (
                  <option
                    value={c.name}
                    data-event={campaignHref(c)}
                    data-month={c.month}
                    data-announce={!c.hash && c.href ? "true" : "false"}
                  >
                    {c.name}
                  </option>
                ))}
              </optgroup>
            ))
          }
        </select>
      </div>
      <button id="shuffle" class="wall-refresh" type="button">↻ 再看幾則</button>
    </section>

    <!-- 選某一期時浮出的緊湊一行：期名 + 則數 + 回活動頁（取代原本佔整排的大白條） -->
    <div class="wall-rail" id="rail" hidden>
      <span class="wall-rail__title" id="rail-title"></span>
      <span class="wall-rail__count" id="rail-count"></span>
      <a
        class="btn btn--ghost"
        id="rail-btn"
        href="#"
        target="_blank"
        rel="noopener">閱讀當期七日書所有文章 →</a
      >
    </div>

    <p class="wall-empty" id="wallempty" hidden>
      這一期還沒有人貼金句 —— 之後讀到喜歡的句子，按「選金句」就會出現在這裡。
    </p>

    <!-- 一整面打散的牆：masonry，金句便利貼貼在白牆上 -->
    <ul class="wall" id="wall">
      <!-- 釘在牆角的本期主題：讀 currentIssue（全站單一來源） -->
      <li class="memo memo--pinned" data-pinned data-campaign={CURRENT_KEY}>
        <div class="memo-card memo-card--pinned">
          <span class="memo-pin" aria-hidden="true">📌</span>
          <p class="memo-pinned__eyebrow">{currentMonth}・本期主題</p>
          <p class="memo-pinned__title">{currentName}</p>
          <p class="memo-pinned__desc">
            本期正在進行 —— 讀到喜歡的句子，按「選金句」就能貼上這面牆。
          </p>
          <a class="memo-pinned__cta" href={currentEvent}>參與本期寫作 →</a>
        </div>
      </li>

      {
        wallQuotes.map((q, i) => (
          <li class="memo" data-variant={i % 6} data-campaign={q.key}>
            <a
              class="memo-card"
              href={articleUrl(q.articleHash)}
              target="_blank"
              rel="noreferrer"
            >
              <blockquote class="memo-quote">{q.content}</blockquote>
              <figcaption class="memo-meta">
                <span class="memo-author">— {q.author}</span>
                <span class="memo-cta" aria-hidden="true">原文 ↗</span>
              </figcaption>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>

<style>
  /* ── 頂部選單（sticky） ───────────────────────────────── */
  .wall-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.6rem clamp(1rem, 4vw, 2.5rem);
    background: rgb(247 247 247 / 92%);
    backdrop-filter: saturate(1.2) blur(8px);
    border-bottom: 1px solid var(--line, #ddd);
  }
  .wall-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: #2a2622;
    text-decoration: none;
  }
  .wall-nav__logo {
    color: #2a2622;
  }
  .wall-nav__brand-text {
    font-family: var(--font-display, sans-serif);
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #2a2622;
  }
  .wall-nav__links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.86rem;
  }
  .wall-nav__links a {
    color: var(--ink, #333);
    text-decoration: none;
  }
  .wall-nav__links a:first-child {
    font-weight: 700;
  }
  .wall-nav__links a:hover {
    color: var(--freewrite-text, #1999d0);
  }
  .wall-nav__matters {
    margin-left: auto;
    color: var(--ink-muted, #808080);
    opacity: 0.7;
  }
  .wall-nav__matters:hover {
    opacity: 1;
  }

  .wall-page {
    max-width: 78rem;
    padding: 1.25rem clamp(1rem, 4vw, 2.5rem) 3rem;
    margin: 0 auto;
  }

  /* ── 控制列 ── */
  .wall-controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    align-items: center;
    margin: 1rem 0 1.25rem;
  }
  .wall-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    flex: 1;
  }
  .wall-filter,
  .wall-shuffle {
    padding: 0.42rem 1rem;
    font-size: 0.9rem;
    color: var(--ink, #333);
    cursor: pointer;
    background: #fff;
    border: 1px solid var(--line, #ddd);
    border-radius: 999px;
    transition: border-color 0.12s ease;
  }
  .wall-filter:hover {
    border-color: #2a2622;
  }
  .wall-filter.is-on {
    font-weight: 700;
    color: #fff;
    background: #2a2622;
    border-color: #2a2622;
  }
  .wall-filter--now {
    color: #8a6d00;
    background: #fff7d6;
    border-color: #e6cf7a;
    font-weight: 700;
  }
  .wall-filter--now.is-on {
    color: #2a2622;
    background: #ffd23f;
    border-color: #ffd23f;
  }
  /* 歷屆下拉：跟籤同一行、pill 樣式 */
  .wall-select {
    max-width: 16rem;
    padding: 0.45rem 0.95rem;
    font-size: 0.9rem;
    color: #2a2622;
    cursor: pointer;
    background: #fff;
    border: 1px solid var(--line, #ddd);
    border-radius: 999px;
  }
  .wall-select:hover {
    border-color: #2a2622;
  }
  .wall-shuffle {
    font-weight: 700;
    white-space: nowrap;
  }
  /* 「再看幾則」：深色實心，放篩選列最右（跟篩選分開） */
  .wall-refresh {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
    padding: 0.45rem 1.05rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    cursor: pointer;
    background: #2a2622;
    border: none;
    border-radius: 8px;
    white-space: nowrap;
  }
  .wall-refresh[hidden] {
    display: none;
  }
  .wall-refresh:hover {
    background: #000;
  }

  /* 選某一期時的緊湊一行（期名 + 則數 + 回活動頁，不再佔整排大白條） */
  .wall-rail {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.8rem;
    margin: 0.25rem 0 1.5rem;
    padding: 0.5rem 0.1rem 0.75rem;
    border-bottom: 1px solid var(--line, #eee);
  }
  .wall-rail[hidden] {
    display: none;
  }
  .wall-rail__title {
    font-family: var(--font-display, sans-serif);
    font-size: 1.1rem;
    font-weight: 800;
    color: #2a2622;
  }
  .wall-rail__count {
    font-size: 0.78rem;
    color: var(--ink-muted, #808080);
  }
  .wall-rail .btn {
    margin-left: auto;
  }

  .btn {
    display: inline-block;
    padding: 0.4rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 999px;
    white-space: nowrap;
  }
  .btn--ghost {
    color: #2a2622;
    background: #fff;
    border: 1px solid var(--line, #ddd);
  }
  .btn--ghost:hover {
    border-color: #2a2622;
  }

  .wall-note {
    margin: 0 0 1.25rem;
    padding: 0.65rem 0.95rem;
    font-size: 0.82rem;
    line-height: 1.65;
    color: #7a6a3c;
    background: #fff7d6;
    border: 1px dashed #e6cf7a;
    border-radius: 0.6rem;
  }
  .wall-empty {
    margin: 0 0 1.25rem;
    padding: 1.5rem 0;
    font-size: 0.9rem;
    color: var(--ink-muted, #808080);
    text-align: center;
  }
  .wall-empty[hidden] {
    display: none;
  }

  /* ── 一整面打散的牆：CSS columns masonry ── */
  .wall {
    column-count: 3;
    column-gap: 1.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  @media (max-width: 920px) {
    .wall { column-count: 2; }
  }
  @media (max-width: 560px) {
    .wall { column-count: 1; }
  }

  .memo {
    display: inline-block;
    width: 100%;
    margin: 0 0 1.5rem;
    break-inside: avoid;
  }
  /* 便利貼：低飽和淡彩底 + 深墨字（讓金句是主體、顏色只是襯托） */
  .memo-card {
    display: block;
    padding: 1.5rem 1.5rem 1.25rem;
    color: #2a2622;
    text-decoration: none;
    background: #fbd7e2; /* 櫻花粉（variant 0） */
    border-radius: 12px;
    box-shadow:
      0 1px 2px rgb(0 0 0 / 5%),
      0 6px 16px rgb(0 0 0 / 7%);
    transform: rotate(-1.2deg);
    transition: transform 0.14s ease, box-shadow 0.14s ease;
  }
  .memo:nth-child(3n) .memo-card { transform: rotate(1deg); }
  .memo:nth-child(4n) .memo-card { transform: rotate(-0.5deg); }
  .memo:nth-child(5n) .memo-card { transform: rotate(0.7deg); }
  .memo-card:hover {
    transform: translateY(-3px) rotate(0deg);
    box-shadow:
      0 2px 6px rgb(0 0 0 / 8%),
      0 12px 24px rgb(0 0 0 / 12%);
  }
  .memo[data-variant="1"] .memo-card { background: #d4eaf6; } /* 霧藍 */
  .memo[data-variant="2"] .memo-card { background: #fbf0c4; } /* 奶油黃 */
  .memo[data-variant="3"] .memo-card { background: #dff0d0; } /* 淺草綠 */
  .memo[data-variant="4"] .memo-card { background: #e7e0fa; } /* 淡薰紫 */
  .memo[data-variant="5"] .memo-card { background: #fce5cf; } /* 淡杏橙 */

  .memo-quote {
    margin: 0;
    font-family: var(--font-family-reading, "Noto Serif TC", serif);
    font-size: 1.06rem;
    line-height: 1.78;
    font-weight: 500;
  }
  .memo-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 1.1rem;
  }
  .memo-author {
    font-size: 0.76rem;
    font-weight: 700;
  }
  .memo-cta {
    font-size: 0.68rem;
    color: rgb(42 38 34 / 60%);
  }

  /* 釘在牆上的本期主題便利貼（深色、有別於金句） */
  .memo--pinned .memo-card--pinned {
    position: relative;
    padding: 1.5rem 1.1rem 1.1rem;
    color: #fff;
    background: linear-gradient(150deg, #5d566b, #6c6573);
    border-radius: 12px;
    box-shadow: 0 8px 20px rgb(0 0 0 / 14%);
    transform: rotate(-1.2deg);
  }
  .memo-pin {
    position: absolute;
    top: -0.55rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 1.2rem;
  }
  .memo-pinned__eyebrow {
    margin: 0 0 0.25rem;
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    color: #ffd23f;
  }
  .memo-pinned__title {
    margin: 0 0 0.4rem;
    font-family: var(--font-display, sans-serif);
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }
  .memo-pinned__desc {
    margin: 0 0 0.85rem;
    font-size: 0.86rem;
    line-height: 1.6;
    color: rgb(255 255 255 / 82%);
  }
  .memo-pinned__cta {
    display: inline-block;
    padding: 0.38rem 0.85rem;
    font-size: 0.8rem;
    font-weight: 700;
    color: #2a2622;
    text-decoration: none;
    background: #ffd23f;
    border-radius: 999px;
  }

  @media (max-width: 760px) {
    .wall-nav {
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    .wall-nav__matters { order: 2; }
    .wall-nav__links { order: 3; width: 100%; }
  }
</style>

<script>
  // 純前端：換一批（每次抽新 24 張）+ 屆數篩選 +（選某期時）浮出回活動頁那一行
  const WINDOW = 16; // 「全部」一次顯示幾張金句；其餘藏著，按「再看幾則」換一批
  const CURRENT_KEY = "__current__"; // 對應釘住的本期便利貼（與 frontmatter 同值）
  const wall = document.getElementById("wall");
  const shuffleBtn = document.getElementById("shuffle");
  const filters = document.getElementById("filters");
  const rail = document.getElementById("rail");
  const railTitle = document.getElementById("rail-title");
  const railCount = document.getElementById("rail-count");
  const railBtn = document.getElementById("rail-btn") as HTMLAnchorElement | null;
  const wallEmpty = document.getElementById("wallempty");

  const pinnedEl = (wall?.querySelector(".memo--pinned") as HTMLElement | null) ?? null;
  const allQuotes = wall
    ? (Array.from(wall.querySelectorAll(".memo:not(.memo--pinned)")) as HTMLElement[])
    : [];
  let currentCampaign = "";

  function shuffled(arr: HTMLElement[]): HTMLElement[] {
    const a = arr.slice();
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const countOf = (name: string) =>
    allQuotes.filter((m) => m.dataset.campaign === name).length;

  // 依目前篩選 + 隨機抽樣，重畫整面牆
  function render() {
    if (!wall) return;
    const isPast = currentCampaign !== "" && currentCampaign !== CURRENT_KEY;
    let shown: HTMLElement[];
    if (currentCampaign === "") {
      shown = shuffled(allQuotes).slice(0, WINDOW); // 全部 → 隨機抽 WINDOW 張
    } else if (currentCampaign === CURRENT_KEY) {
      shown = []; // 本期 → 只留釘住那張
    } else {
      shown = shuffled(allQuotes.filter((m) => m.dataset.campaign === currentCampaign));
    }
    const showSet = new Set(shown);
    allQuotes.forEach((m) => {
      m.style.display = showSet.has(m) ? "" : "none";
    });
    const showPinned = currentCampaign === "" || currentCampaign === CURRENT_KEY;
    if (pinnedEl) pinnedEl.style.display = showPinned ? "" : "none";
    // 釘住那張在最前，其餘照抽到的順序
    const order: HTMLElement[] = [];
    if (pinnedEl && showPinned) order.push(pinnedEl);
    order.push(...shown);
    order.forEach((el) => wall.appendChild(el));
    // 選到某一期、但這期還沒有金句 → 顯示空狀態
    if (wallEmpty) wallEmpty.hidden = !(isPast && shown.length === 0);
    // 「再看幾則」只在「全部」時有意義（篩某一期是顯示該期全部、不抽樣）
    if (shuffleBtn) shuffleBtn.hidden = currentCampaign !== "";
  }

  const select = document.getElementById("campaign-select") as HTMLSelectElement | null;

  // 浮出/收起「活動日期 + 回活動頁」那一行
  function updateRail(name: string, ev: string, month: string, isAnnounce: boolean) {
    if (!rail) return;
    const isPast = name !== "" && name !== CURRENT_KEY;
    if (isPast && railBtn) {
      if (railTitle) railTitle.textContent = name;
      if (railCount) railCount.textContent = month ? `活動日期：${month}` : "";
      railBtn.textContent = isAnnounce ? "閱讀當期公告 →" : "閱讀當期七日書所有文章 →";
      railBtn.href = ev || "#";
      rail.hidden = false;
    } else {
      rail.hidden = true; // 「全部」「本期」不顯示這一行
    }
  }

  function selectCampaign(name: string, ev: string, month: string, isAnnounce: boolean) {
    currentCampaign = name;
    render();
    updateRail(name, ev, month, isAnnounce);
  }

  shuffleBtn?.addEventListener("click", render); // 換一批 = 重抽一批

  // 點「全部」/「本期」籤
  const allChip = filters?.querySelector('.wall-filter[data-campaign=""]');
  filters?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest(".wall-filter") as HTMLElement | null;
    if (!btn) return;
    filters.querySelectorAll(".wall-filter").forEach((b) => b.classList.remove("is-on"));
    btn.classList.add("is-on");
    if (select) select.value = ""; // 點籤就把歷屆下拉重置
    selectCampaign(btn.dataset.campaign || "", btn.dataset.event || "", "", false);
  });

  // 「瀏覽歷屆」下拉
  select?.addEventListener("change", () => {
    filters?.querySelectorAll(".wall-filter").forEach((b) => b.classList.remove("is-on"));
    if (!select.value) {
      allChip?.classList.add("is-on"); // 選回「瀏覽歷屆⋯」= 回全部
      selectCampaign("", "", "", false);
      return;
    }
    const opt = select.options[select.selectedIndex];
    selectCampaign(
      select.value,
      opt.dataset.event || "",
      opt.dataset.month || "",
      opt.dataset.announce === "true",
    );
  });

  render();
</script>
