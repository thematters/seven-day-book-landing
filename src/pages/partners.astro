---
// 舊路徑 redirect /partners/ → /partnership/
// 切換正式網址前部分既有外連可能還用 /partners/，保留此檔做 client-side redirect
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";
import "../styles/seven-day-campaign.css";

const partnershipHref = withBase("partnership/");
---

<BaseLayout
  title="七日書機構合作"
  description="七日書機構合作入口已移至 /partnership/。"
>
  <main class="redirect-page">
    <div>
      <h1>七日書機構合作頁已移動</h1>
      <p>新的入口在 /partnership/，請前往：</p>
      <p class="redirect-page__action">
        <a
          class="button button--primary"
          href={partnershipHref}
          data-redirect-target>前往機構合作頁</a
        >
      </p>
    </div>
  </main>
  <script is:inline>
    const target = document
      .querySelector("[data-redirect-target]")
      ?.getAttribute("href");
    if (target) window.location.replace(target);
  </script>
</BaseLayout>
