---
import BaseLayout from "../layouts/BaseLayout.astro";
import GrandBadge from "../components/GrandBadge.astro";
import MattersWordmark from "../components/MattersWordmark.astro";
import SevenDayBookLogo from "../components/SevenDayBookLogo.astro";
import WritingCardGrid from "../components/WritingCardGrid.astro";
import {
  contactEmail,
  historicalThemes,
  latestArticles,
  lectures,
  partnerFaq,
  partnerPage,
  shared,
} from "../data/seven-day-campaign";
import "../styles/seven-day-campaign.css";
import { withBase } from "../utils/paths";

const homeHref = withBase("");
const museumHref = withBase("museum/");
const assetSrc = (src?: string) => {
  if (!src) return "";
  return src.startsWith("http") ? src : withBase(src);
};
const nav = [
  { href: homeHref, label: "七日書介紹" },
  { href: museumHref, label: "博物館" },
  { href: "#impact", label: "參與數據" },
  { href: "#themes", label: "歷次主題" },
  { href: "#packages", label: "合作內容" },
  { href: "#faq", label: "FAQ" },
];
const marqueeAvatars = [
  ...shared.avatarWall.slice(0, 24),
  ...shared.avatarWall.slice(0, 24),
];

---

<BaseLayout title="七日書機構合作" description={partnerPage.description}>
  <div class="campaign-page" data-page="partners">
    <header class="sitebar">
      <a
        class="sitebar__brand"
        href="https://matters.town"
        target="_blank"
        rel="noopener"
        aria-label="Matters · 七日書 · 合作"
      >
        <MattersWordmark size={18} />
        <span class="sitebar__dot" aria-hidden="true">·</span>
        <SevenDayBookLogo size={20} title="七日書" />
        <span class="sitebar__brand-suffix">合作</span>
      </a>

      <nav class="sitebar__nav" aria-label="頁面導覽">
        {nav.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>

      <div class="sitebar__actions">
        <a
          class="button button--primary"
          data-contact-copy={shared.contactEmailPlain}
          href={shared.contactHref}
          >{partnerPage.hero.primaryLabel}</a
        >
      </div>
    </header>

    <main>
      <section class="hero hero--stacked" aria-labelledby="partner-hero-title">
        <div class="hero__banner" aria-hidden="true">
          <img
            src={assetSrc(partnerPage.heroBanner)}
            alt=""
            loading="eager"
          />
        </div>
        <div class="hero__copy">
          <p class="eyebrow">{partnerPage.hero.eyebrow}</p>
          <h1 id="partner-hero-title">
            {partnerPage.hero.headlineLine1}<br />{partnerPage.hero.headlineLine2}
          </h1>
          <p class="hero__lead">{partnerPage.hero.lead}</p>
          <div class="hero__meta" aria-label="合作重點">
            <span class="pill">冠名支持</span>
            <span class="pill">客製活動</span>
            <span class="pill">贊助出題</span>
          </div>
          <div class="hero__actions">
            <a
              class="button button--primary"
              data-contact-copy={shared.contactEmailPlain}
              href={shared.contactHref}
              >洽談合作</a
            >
            <a class="button button--soft" href={homeHref}>加入寫作</a>
          </div>
        </div>
      </section>

      <section
        id="impact"
        class="section section--paper"
        aria-labelledby="impact-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">累積參與</p>
            <h2 id="impact-title">七日書已經累積成一個能量豐富的書寫社群。</h2>
            <p>
              對合作夥伴而言，七日書重點除了流量，更在於同一命題下的真實回應。
            </p>
          </header>

          <div class="metrics-grid">
            {
              partnerPage.impact.map((item) => (
                <article
                  class={`metric-card ${item.emphasis ? "metric-card--emphasis" : ""}`}
                >
                  <strong>{item.value}</strong>
                  <span>{item.label}</span>
                </article>
              ))
            }
          </div>

          <div class="avatar-marquee" aria-label="七日書創作者頭像">
            <div class="avatar-marquee__track">
              {
                marqueeAvatars.map((avatar) => (
                  <a
                    href={`https://matters.town/@${avatar.handle}`}
                    target="_blank"
                    rel="noopener"
                    title={avatar.name}
                  >
                    <img
                      src={assetSrc(avatar.src)}
                      alt={avatar.name}
                      loading="lazy"
                    />
                  </a>
                ))
              }
            </div>
          </div>

          <div class="signal-grid signal-grid--spaced">
            {
              partnerPage.businessSignals.map((item) => (
                <article class="signal-card">
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        id="themes"
        class="section section--paper"
        aria-labelledby="themes-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">七日書歷次主題</p>
            <h2 id="themes-title">每期都是一個可以被社群長時間回應的命題。</h2>
            <p>
              從生活、感官、身份到公共議題，七日書把抽象命題轉成能讓人回到自身經驗的七天提問。
            </p>
          </header>

          <div class="theme-list" data-theme-collapse data-collapsed-count="3">
            {
              historicalThemes.map((theme, idx) => (
                <a
                  class="theme-row"
                  href={theme.announceHref}
                  target="_blank"
                  rel="noopener"
                  data-theme-row-index={idx}
                  hidden={idx >= 3}
                >
                  <div class="theme-row__media">
                    <img
                      src={assetSrc(theme.announceCover)}
                      alt=""
                      loading="lazy"
                    />
                  </div>
                  <div>
                    <h3>{theme.name}</h3>
                    <p>
                      {theme.announceSummary && theme.announceSummary.length > 90
                        ? theme.announceSummary.slice(0, 90) + "…"
                        : theme.announceSummary}
                    </p>
                    {theme.participants && (
                      <p class="theme-row__participants">
                        {theme.participants} 位文友參與
                        {theme.newcomers ? ` · ${theme.newcomers} 位新作者` : ""}
                        {theme.completers ? ` · ${theme.completers} 位寫滿七篇` : ""}
                      </p>
                    )}
                  </div>
                  <div class="theme-row__date">
                    <span class="theme-row__series">第 {theme.series.replace(/^S/, "")} 期</span>
                    <span>{theme.monthLabel}</span>
                  </div>
                </a>
              ))
            }
          </div>
          <div class="theme-pager__more">
            <button
              class="button button--quiet"
              type="button"
              data-theme-expand
              aria-expanded="false"
            >
              <span data-expand-label
                >展開更多 {historicalThemes.length - 3} 期 ↓</span
              >
            </button>
            <a class="button button--quiet" href={withBase("museum/")}
              >查看完整七日書博物館 →</a
            >
          </div>
        </div>
      </section>

      <section
        id="execution"
        class="section section--soft"
        aria-labelledby="execution-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">七日書執行內容</p>
            <h2 id="execution-title">
              <span class="nowrap-group">從題目設計，</span><span class="nowrap-group">到七天書寫，</span><span class="nowrap-group">再到可保存的成果。</span>
            </h2>
            <p>
              七日書已從單次徵文，發展為一套有節奏、有陪伴感，並能持續沉澱內容資產的書寫機制。
            </p>
          </header>

          <div class="flow-grid">
            {
              partnerPage.executionIntro.map((item) => (
                <article class="flow-card">
                  <span class="flow-card__step">{item.step}</span>
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        id="lectures"
        class="section section--soft"
        aria-labelledby="lectures-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">名家講座</p>
            <h2 id="lectures-title">講座讓題目從活動週延伸成內容資產。</h2>
            <p>
              當講座被整理成文字，它就能繼續被搜尋、引用、轉寄，也能成為下一波討論的起點。從 2024 年至今，七日書共邀請 {lectures.length} 位講者陪文友書寫，其中 {lectures.filter((l) => l.hasTranscript).length} 場留下完整文字精華。
            </p>
          </header>

          <div class="lecture-grid lecture-grid--dense">
            {
              /* CC #2：有文字稿（hasTranscript）的講者排前面、整理中的排後面。
               * 用 stable sort：穩定 false 之前的相對順序不變。 */
              [...lectures]
                .sort((a, b) => Number(b.hasTranscript) - Number(a.hasTranscript))
                .map((lecture) => {
                return (
                  <article class="lecture-card lecture-card--compact">
                    <div class="lecture-card__speaker lecture-card__speaker--text">
                      <strong>{lecture.speaker}</strong>
                      <span>
                        {lecture.role} · {lecture.theme}
                      </span>
                    </div>
                    {lecture.hasTranscript ? (
                      <>
                        <p class="lecture-card__excerpt">
                          {lecture.summary &&
                            (lecture.summary.length > 80
                              ? lecture.summary.slice(0, 80) + "…"
                              : lecture.summary)}
                        </p>
                        <a
                          class="lecture-card__link"
                          href={lecture.href}
                          target="_blank"
                          rel="noopener"
                        >
                          閱讀文字精華 →
                        </a>
                      </>
                    ) : (
                      <>
                        <p class="lecture-card__excerpt">{lecture.note}</p>
                        <span class="lecture-card__pill">講座記錄整理中</span>
                      </>
                    )}
                  </article>
                );
              })
            }
          </div>
        </div>
      </section>

      <section
        id="articles"
        class="section section--paper"
        aria-labelledby="articles-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">精選文章</p>
            <h2 id="articles-title">
              最近一期作品，可以直接看到社群如何回應題目。
            </h2>
            <p>文章不是活動的附屬成果，而是合作題目真正被生活回答的地方。</p>
          </header>

          <WritingCardGrid articles={latestArticles} />
        </div>
      </section>

      <section
        id="case"
        class="section section--soft"
        aria-labelledby="case-title"
      >
        <div class="section__inner case-study">
          <div>
            <div class="case-study__image">
              <img
                src={assetSrc(partnerPage.caseStudy.image)}
                alt={partnerPage.caseStudy.title}
                loading="lazy"
              />
            </div>
            {
              partnerPage.caseStudy.gallery &&
                partnerPage.caseStudy.gallery.length > 1 && (
                  <div class="case-study__gallery">
                    {partnerPage.caseStudy.gallery
                      .slice(1)
                      .map((src) => (
                        <img src={assetSrc(src)} alt="" loading="lazy" />
                      ))}
                  </div>
                )
            }
          </div>
          <div class="case-study__copy">
            <p class="eyebrow">合作案例</p>
            <h2 id="case-title">{partnerPage.caseStudy.headline}</h2>
            <p><strong>{partnerPage.caseStudy.title}</strong></p>
            <p>{partnerPage.caseStudy.summary}</p>
            <ul class="fact-list">
              {partnerPage.caseStudy.facts.map((fact) => <li>{fact}</li>)}
            </ul>
            {
              partnerPage.caseStudy.relatedArticles &&
                partnerPage.caseStudy.relatedArticles.length > 0 && (
                  <div class="case-study__related">
                    <p class="eyebrow">相關文章</p>
                    <ul>
                      {partnerPage.caseStudy.relatedArticles.map((a) => (
                        <li>
                          <a href={a.href} target="_blank" rel="noopener">
                            {a.title} →
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
            }
          </div>
        </div>
      </section>

      <section
        id="packages"
        class="section section--paper"
        aria-labelledby="packages-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">合作內容</p>
            <h2 id="packages-title">把合作拆成可選、可組合的三個模組。</h2>
          </header>

          <div class="package-grid">
            {
              partnerPage.packages.map((item) => (
                <article class="package-card">
                  <span
                    class={`package-card__icon package-card__icon--${item.iconKind}`}
                    aria-hidden="true"
                  >
                    <GrandBadge size={44} title={item.title} />
                  </span>
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <section
        id="faq"
        class="section section--soft"
        aria-labelledby="faq-title"
      >
        <div class="section__inner">
          <header class="section__header">
            <p class="eyebrow">FAQ</p>
            <h2 id="faq-title">{partnerPage.faqHeading}</h2>
          </header>

          <div class="faq-list">
            {
              partnerFaq.map((item) => (
                <details>
                  <summary>{item.q}</summary>
                  <p>{item.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="partner-cta-title">
        <div class="section__inner">
          <div class="cta-band">
            <h2 id="partner-cta-title">{partnerPage.cta.headline}</h2>
            <p>{partnerPage.cta.body}</p>
            <div class="cta-band__actions">
              <a class="button button--primary" data-contact-copy={shared.contactEmailPlain} href={shared.contactHref}
                >{partnerPage.cta.primaryLabel}</a
              >
              <a class="button button--soft" href={homeHref}
                >{partnerPage.cta.secondaryLabel}</a
              >
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="page-footer">
      <span
        >合作洽談：<a href={`mailto:${contactEmail}`}>{contactEmail}</a></span
      >
      <span><a href={homeHref}>回到寫作者入口 →</a></span>
    </footer>
  </div>

  <script is:inline>
    // v3: 「洽談合作」mailto 點擊時同時複製 email 到剪貼簿 + 顯示 toast
    // 避免使用者沒設預設信箱以為按鈕壞了
    document.querySelectorAll("[data-contact-copy]").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        const email = btn.getAttribute("data-contact-copy") || "";
        // 嘗試 copy；不影響 mailto 預設動作（沒設信箱也會被 OS 默默吃掉）
        if (navigator.clipboard && email) {
          navigator.clipboard.writeText(email).catch(() => {});
        }
        // 顯示 toast
        let toast = document.getElementById("contact-toast");
        if (!toast) {
          toast = document.createElement("div");
          toast.id = "contact-toast";
          toast.className = "contact-toast";
          document.body.appendChild(toast);
        }
        toast.textContent = `已複製 ${email} ✓ 如沒開啟信箱，請貼到 Gmail/Outlook 開信`;
        toast.classList.add("contact-toast--visible");
        clearTimeout(toast._timer);
        toast._timer = setTimeout(() => {
          toast.classList.remove("contact-toast--visible");
        }, 4000);
      });
    });

    // 歷次主題：預設展示 3 期，點按鈕展開全部
    const expandBtn = document.querySelector("[data-theme-expand]");
    const collapseList = document.querySelector("[data-theme-collapse]");
    if (expandBtn && collapseList) {
      const initial = Number(collapseList.getAttribute("data-collapsed-count") || "3");
      const allRows = collapseList.querySelectorAll("[data-theme-row-index]");
      const total = allRows.length;
      const labelEl = expandBtn.querySelector("[data-expand-label]");
      let expanded = false;
      expandBtn.addEventListener("click", () => {
        expanded = !expanded;
        allRows.forEach((row, idx) => {
          if (expanded || idx < initial) row.removeAttribute("hidden");
          else row.setAttribute("hidden", "");
        });
        expandBtn.setAttribute("aria-expanded", String(expanded));
        if (labelEl) {
          labelEl.textContent = expanded
            ? "收起，只看最近 " + initial + " 期 ↑"
            : "展開更多 " + (total - initial) + " 期 ↓";
        }
      });
    }
  </script>
</BaseLayout>
