---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";
import "../styles/seven-day-campaign.css";

const partnersHref = withBase("partners/");
---

<BaseLayout
  title="七日書機構合作"
  description="七日書機構合作入口已移至新的 partners 頁面。"
>
  <main class="redirect-page">
    <div>
      <h1>七日書機構合作頁已移動</h1>
      <p>請前往新的合作入口。</p>
      <p class="redirect-page__action">
        <a
          class="button button--primary"
          href={partnersHref}
          data-redirect-target>前往機構合作頁</a
        >
      </p>
    </div>
  </main>
  <script is:inline>
    const target = document
      .querySelector("[data-redirect-target]")
      ?.getAttribute("href");
    if (target) window.location.replace(target);
  </script>
</BaseLayout>
